%% uc_04_permission_hierarchy.mmd — Access-Control Overview
%% Mermaid approximation of a UML use case diagram.
%% Detail files:
%%   - uc_04a_system_admin_surface.mmd
%%   - uc_04b_org_project_access.mmd

flowchart LR
    superadmin["<<actor>> Superadmin"]
    systemAdmin["<<actor>> System Admin"]
    orgOwner["<<actor>> Org Owner"]
    orgAdmin["<<actor>> Org Admin"]
    projectOwner["<<actor>> Project Owner"]
    projectManager["<<actor>> Project Manager"]
    projectMember["<<actor>> Project Member"]
    projectViewer["<<actor>> Project Viewer"]

    subgraph system["Access-Control Surfaces"]
        systemSurface([Use system admin workspace])
        orgSurface([Use organization admin workspace])
        projectSurface([Use project and task workspace])
        marketplaceSurface([Use marketplace and reviews])
        settingsSurface([Use personal settings workspace])
        notificationSurface([Use notification center workspace])
    end

    superadmin --> systemSurface
    systemAdmin --> systemSurface
    orgOwner --> orgSurface
    orgAdmin --> orgSurface
    projectOwner --> projectSurface
    projectManager --> projectSurface
    projectMember --> projectSurface
    projectViewer --> projectSurface
    projectMember --> marketplaceSurface
    projectViewer --> settingsSurface
    projectViewer --> notificationSurface

    superadmin -.->|generalization| systemAdmin
    orgOwner -.->|generalization| orgAdmin
    projectOwner -.->|generalization| projectManager
    projectManager -.->|generalization| projectMember
    projectMember -.->|generalization| projectViewer

    classDef actor fill:#E3F2FD,stroke:#1565C0,color:#333
    classDef usecase fill:#FFF3E0,stroke:#E65100,color:#333
    class superadmin,systemAdmin,orgOwner,orgAdmin,projectOwner,projectManager,projectMember,projectViewer actor
    class systemSurface,orgSurface,projectSurface,marketplaceSurface,settingsSurface,notificationSurface usecase
