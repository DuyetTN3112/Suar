    subgraph system["Project & Task Workspace"]
        projectGov([Manage project scope and roster])
        taskAuthor([Author and maintain task details])
        taskFlow([Execute task workflow])
        taskViews([View boards, timeline, and audit history])
        workflowSetup([Configure task statuses and transitions])
    end

    projectOwner --> projectGov
    projectManager --> taskAuthor
    projectManager --> taskFlow
    projectMember --> taskFlow
    projectMember --> taskViews
    projectViewer --> taskViews
    orgAdmin --> workflowSetup
    projectOwner --> workflowSetup

    projectOwner -.->|generalization| projectManager
    projectManager -.->|generalization| projectMember
    projectMember -.->|generalization| projectViewer

    classDef actor fill:#E3F2FD,stroke:#1565C0,color:#333
    classDef usecase fill:#FFF3E0,stroke:#E65100,color:#333
