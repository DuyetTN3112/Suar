
%% ERD: Organization & Project Domain
%% Source: app/models/organization.ts, organization_user.ts,
%%         project.ts, project_member.ts, project_attachment.ts,
%% Scope: organization/project ownership, membership, attachments.
%% Convention: table/column only. No relationship edges or FK markers.
%% Runtime notes:
%%   - organizations.plan là legacy schema field; product package không còn đặt ở organization level
%%   - invitation/join request source-of-truth hiện là organization_users với status = pending
%%   - nghiệp vụ chuẩn hiện là organization -> project -> task
erDiagram
    organizations {
        UUID id PK
        VARCHAR name
        VARCHAR slug UK
        TEXT description
        VARCHAR logo
        VARCHAR website
        VARCHAR plan "legacy schema field"
        UUID owner_id
        JSONB custom_roles
        VARCHAR partner_type "gold/silver/bronze"
        TIMESTAMPTZ partner_verified_at
        UUID partner_verified_by
        TEXT partner_verification_proof
        TIMESTAMPTZ partner_expires_at
        BOOLEAN partner_is_active
        TIMESTAMPTZ deleted_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    organization_users {
        UUID organization_id PK
        UUID user_id PK
        VARCHAR org_role "org_owner/org_admin/org_member"
        VARCHAR status "pending/approved/rejected"
        UUID invited_by
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    projects {
        UUID id PK
        UUID creator_id
        VARCHAR name
        TEXT description
        UUID organization_id
        TIMESTAMPTZ start_date
        TIMESTAMPTZ end_date
        VARCHAR status "pending/in_progress/completed/cancelled"
        NUMERIC budget
        UUID manager_id
        UUID owner_id
        VARCHAR visibility "public/private/team"
        BOOLEAN allow_freelancer
        BOOLEAN approval_required_for_members
        JSONB tags
        JSONB custom_roles
        TIMESTAMPTZ deleted_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    project_members {
        UUID project_id PK
        UUID user_id PK
        VARCHAR project_role "project_owner/project_manager/project_member/project_viewer"
        TIMESTAMPTZ created_at
    }

    project_attachments {
        UUID id PK
        UUID project_id
        VARCHAR file_name
        VARCHAR file_path
        UUID uploaded_by
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
