
%% ERD: Task & Marketplace Domain
%% Source: app/infra/tasks/models/task.ts, task_status.ts, task_workflow_transition.ts,
%%         task_version.ts, task_application.ts, task_assignment.ts,
%%         task_required_skill.ts
%% Scope: current task runtime + marketplace-supporting tables.
%% Convention: table/column only. No relationship edges or FK markers.
%% Runtime notes:
%%   - tasks.project_id là bắt buộc theo product truth
%%   - task_status_id là workflow source-of-truth; tasks.status chỉ còn legacy compatibility
%%   - app layer vẫn phải enforce organization_id khớp với project.organization_id
erDiagram
    task_statuses {
        UUID id PK
        UUID organization_id
        VARCHAR name "Display name"
        VARCHAR slug "UK(org, slug)"
        VARCHAR category "todo/in_progress/done/cancelled"
        VARCHAR color "#hex"
        VARCHAR icon "nullable"
        VARCHAR description "nullable"
        INT sort_order
        BOOLEAN is_default
        BOOLEAN is_system "cannot delete"
        TIMESTAMPTZ deleted_at "soft delete"
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    task_workflow_transitions {
        UUID id PK
        UUID organization_id
        UUID from_status_id
        UUID to_status_id
        JSONB conditions "e.g. requires_assignee"
        TIMESTAMPTZ created_at
    }

    tasks {
        UUID id PK
        VARCHAR title
        TEXT description
        VARCHAR status "legacy category compatibility"
        UUID task_status_id "nullable during rollout"
        VARCHAR label "bug/feature/enhancement/documentation"
        VARCHAR priority "low/medium/high/urgent"
        VARCHAR difficulty "easy/medium/hard/expert"
        UUID assigned_to
        UUID creator_id
        UUID updated_by
        TIMESTAMPTZ due_date
        UUID parent_task_id
        NUMERIC estimated_time
        NUMERIC actual_time
        UUID organization_id
        UUID project_id "required by runtime truth"
        VARCHAR task_visibility "internal/external/all"
        TIMESTAMPTZ application_deadline
        VARCHAR task_type
        TEXT acceptance_criteria
        VARCHAR verification_method
        JSONB expected_deliverables
        TEXT context_background
        TEXT impact_scope
        JSONB tech_stack
        VARCHAR environment
        VARCHAR collaboration_type
        TEXT complexity_notes
        JSONB measurable_outcomes
        JSONB learning_objectives
        JSONB domain_tags
        VARCHAR role_in_task
        VARCHAR autonomy_level
        VARCHAR problem_category
        VARCHAR business_domain
        INT estimated_users_affected
        NUMERIC estimated_budget
        INT external_applications_count
        INT sort_order
        TIMESTAMPTZ deleted_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    task_versions {
        UUID id PK
        UUID task_id
        VARCHAR title
        TEXT description
        VARCHAR status
        VARCHAR label
        VARCHAR priority
        VARCHAR difficulty
        UUID assigned_to
        UUID changed_by
        TIMESTAMPTZ changed_at
    }

    task_applications {
        UUID id PK
        UUID task_id
        UUID applicant_id
        VARCHAR application_status "pending/approved/rejected/withdrawn"
        VARCHAR application_source "public_listing/invitation/referral"
        TEXT message
        NUMERIC expected_rate
        JSONB portfolio_links
        UUID reviewed_by
        VARCHAR rejection_reason
        TIMESTAMPTZ applied_at "autoCreate (replaces created_at)"
        TIMESTAMPTZ reviewed_at
    }

    task_assignments {
        UUID id PK
        UUID task_id
        UUID assignee_id
        UUID assigned_by
        VARCHAR assignment_type "member/freelancer/volunteer"
        VARCHAR assignment_status "active/completed/cancelled"
        NUMERIC estimated_hours
        NUMERIC actual_hours
        INT progress_percentage
        TEXT completion_notes
        UUID verified_by "exists but NEVER SET"
        TIMESTAMPTZ verified_at "exists but NEVER SET"
        TIMESTAMPTZ assigned_at "autoCreate (replaces created_at)"
        TIMESTAMPTZ completed_at
    }

    task_required_skills {
        UUID id PK
        UUID task_id
        UUID skill_id
        VARCHAR required_level_code "beginner~master"
        BOOLEAN is_mandatory
        TIMESTAMPTZ created_at
    }
