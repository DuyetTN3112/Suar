
%% ERD: User, Auth, Skills Domain
%% Source: app/models/user.ts, user_oauth_provider.ts, skill.ts,
%%         user_skill.ts, recruiter_bookmark.ts
%% Supplemental refs: app/types/database.ts (remember_me_tokens),
%%                    app/infra/admin/repositories/admin_subscription_repository.ts (user_subscriptions)
%% Convention: table/column only. No relationship edges or FK markers.
%% Runtime notes:
%%   - auth_method: google | github
%%   - recruiter_bookmarks exists at schema/model level but has no active route/controller surface
%%   - subscriptions are user-account level in product, while schema plan values still read free/pro/enterprise
erDiagram
    users {
        UUID id PK
        VARCHAR username UK
        VARCHAR email UK
        VARCHAR status "active/inactive/suspended"
        VARCHAR system_role "superadmin/system_admin/registered_user"
        UUID current_organization_id
        VARCHAR auth_method "google/github"
        VARCHAR avatar_url
        TEXT bio
        VARCHAR phone
        TEXT address
        VARCHAR timezone
        VARCHAR language
        BOOLEAN is_freelancer
        NUMERIC freelancer_rating
        INT freelancer_completed_tasks_count
        JSONB profile_settings
        JSONB trust_data
        JSONB credibility_data
        TIMESTAMPTZ deleted_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    user_oauth_providers {
        UUID id PK
        UUID user_id
        VARCHAR provider "google/github"
        VARCHAR provider_id UK
        VARCHAR email
        VARCHAR access_token
        VARCHAR refresh_token
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    remember_me_tokens {
        SERIAL id PK
        UUID tokenable_id
        VARCHAR hash
        TIMESTAMPTZ expires_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    skills {
        UUID id PK
        VARCHAR category_code "technical/soft_skill/delivery"
        VARCHAR display_type "spider_chart/list"
        VARCHAR skill_code UK
        VARCHAR skill_name
        TEXT description
        VARCHAR icon_url
        BOOLEAN is_active
        INT sort_order
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    user_skills {
        UUID id PK
        UUID user_id
        UUID skill_id
        VARCHAR level_code "beginner~master"
        VARCHAR source "imported/reviewed"
        INT total_reviews
        NUMERIC avg_score
        NUMERIC avg_percentage
        TIMESTAMPTZ last_reviewed_at
        TIMESTAMPTZ last_calculated_at
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    recruiter_bookmarks {
        UUID id PK
        UUID recruiter_user_id
        UUID talent_user_id
        TEXT notes
        VARCHAR folder
        SMALLINT rating "1~5"
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    user_subscriptions {
        UUID id PK
        UUID user_id
        VARCHAR plan "schema: free/pro/enterprise"
        VARCHAR status "active/expired/cancelled"
        TIMESTAMPTZ started_at
        TIMESTAMPTZ expires_at
        BOOLEAN auto_renew
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }
