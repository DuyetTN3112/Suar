%% Architecture Diagram: Layered Architecture
%% Cross-referenced with actual backend code 2024
%% ⚠️ Fixed: 107 → 110 controllers, 55 → 58 commands
%% ❌ Fixed: Middleware names (no permission/silent_auth → authorize_role/require_organization/guest)
%% ❌ Fixed: Transmit real-time broadcast NOT working (transport=null)
flowchart TD
    subgraph presentation["Presentation Layer"]
        direction LR
        Routes["Routes
        (start/routes/*.ts)
        12 route files"]
        Controllers["110 Thin Controllers
        (zero Model imports)
        ──────────────
        Parse request → call Action\n→ return response"]
        Middleware["Middleware
        (auth, guest,
        authorize_role,
        require_organization,
        throttle, audit_log)"]
    end

    subgraph application["Application Layer (CQRS)"]
        direction LR
        DTOs["DTOs
        (Data Transfer Objects)
        ──────────────
        Type-safe input/output
        contracts between layers"]
        Commands["Commands
        (59 action files)
        ──────────────
        Write operations:
        Create, Update, Delete
        Business rule validation"]
        Queries["Queries
        ──────────────
        Read operations:
        List, Detail, Filter
        Optimized SELECT"]
        Rules["Pure Rules
        (PolicyResult pattern)
        ──────────────
        6 rule modules:
        Task · Project · Org
        Conversation · Review · User
        100% testable, 0 DB deps"]
    end

    subgraph domain["Domain Layer"]
        direction LR
        Models["Fat Models
        (Lucid ORM)
        ──────────────
        27 Lucid + 3 Mongoose
        models with
        static methods,
        scopes, hooks,
        computed properties"]
        PermService["PermissionService
        (17 methods, cached)
        ──────────────
        System → Org → Project
        3-tier permission check
        with custom role fallback"]
        Validators["Validators
        (VineJS)
        ──────────────
        Input validation
        with type inference"]
    end

    subgraph infrastructure["Infrastructure Layer"]
        direction LR
        PostgreSQL[("PostgreSQL
        27 tables
        UUIDv7, no FK")]
        MongoDB[("MongoDB Atlas
        audit_logs
        notifications
        user_activity_logs")]
        RepoFactory["RepositoryFactory
        ──────────────
        Toggle between
        PostgreSQL ↔ MongoDB
        for audit/notification"]
    end

    subgraph crosscutting["Cross-Cutting Concerns"]
        direction LR
        EventBus["Event Bus
        (Emitter)
        ──────────────
        49 emit calls
        across 58 commands"]
        Listeners["Listeners
        ──────────────
        • TriggerListener
        • AuditLogListener
        • CacheInvalidation
        • NotificationListener
        • ReviewListener
        • CleanupListener
        • ActivityListener"]
        Cache["Redis Cache
        ──────────────
        Permission cache
        Data cache
        SingleFlight"]
        WebSocket["WebSocket / SSE
        (Transmit)
        ──────────────
        ⚠️ transport=null
        NOT delivering messages"]
    end

    %% Presentation → Application
    Routes --> Controllers
    Controllers --> Middleware
    Controllers -->|"call with DTO"| Commands
    Controllers -->|"call with DTO"| Queries

    %% Application → Rules (pure)
    Commands -->|"enforce
    business rules"| Rules

    %% Application → Domain
    Commands -->|"validate input"| Validators
    Queries -->|"validate input"| Validators
    Commands -->|"check permissions"| PermService
    Queries -->|"check permissions"| PermService
    Commands -->|"read/write via
    static methods"| Models
    Queries -->|"read via
    scopes + queries"| Models

    %% Domain → Infrastructure
    Models -->|"Lucid ORM
    query builder"| PostgreSQL
    RepoFactory -->|"write async"| MongoDB
    PermService -->|"cache lookup
    / invalidate"| Cache

    %% Cross-cutting flows
    Commands -->|"emit domain
    events"| EventBus
    EventBus -->|"async dispatch"| Listeners
    Listeners -->|"audit log"| RepoFactory
    Listeners -->|"invalidate"| Cache
    Listeners -->|"broadcast"| WebSocket

    classDef presStyle fill:#E3F2FD,stroke:#1565C0,color:#333,stroke-width:2px
    classDef appStyle fill:#FFF9C4,stroke:#F57F17,color:#333,stroke-width:2px
    classDef domStyle fill:#FCE4EC,stroke:#C62828,color:#333,stroke-width:2px
    classDef infraStyle fill:#E8F5E9,stroke:#2E7D32,color:#333,stroke-width:2px
    classDef crossStyle fill:#F3E5F5,stroke:#7B1FA2,color:#333,stroke-width:2px
    class Routes,Controllers,Middleware presStyle
    class DTOs,Commands,Queries,Rules appStyle
    class Models,PermService,Validators domStyle
    class PostgreSQL,MongoDB,RepoFactory infraStyle
    class EventBus,Listeners,Cache,WebSocket crossStyle


