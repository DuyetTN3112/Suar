flowchart TD
    Presentation["Presentation Layer\nroutes, middleware, controllers, Inertia pages"]
    AppApi["Action Public API Boundary\napp/modules/*/actions/public_api.ts"]
    Bootstrap["Bootstrap Layer\ncomposition root + action factory\nmonolith cross-module adapters"]
    Application["Application Layer\nactor contexts, ports, DTOs\nmappers, module services"]
    Domain["Domain Layer\npure entities, formulas\npolicies, state rules"]
    Infrastructure["Infrastructure Layer\nrepositories, ORM/Mongo/cache adapters\nrepository providers + barrels"]
    Data["Data Layer\nPostgreSQL, MongoDB, Redis"]
    Runtime["Runtime Support\nevents, listeners, cache invalidation\ninactive realtime"]
    EmptyLegacy["Drained Legacy Boundaries\napp/actions/shared and app/services\nno active TS files"]

    Presentation --> AppApi
    AppApi --> Bootstrap
    Bootstrap --> Application
    Application --> Domain
    Application --> Infrastructure
    Infrastructure --> Data
    Application --> Runtime
    Runtime --> AppApi
    Runtime --> Infrastructure
    AppApi -.-> EmptyLegacy

    classDef layer fill:#E3F2FD,stroke:#1565C0,color:#333
    classDef boundary fill:#FFF9C4,stroke:#F57F17,color:#333
    classDef bootstrap fill:#FCE4EC,stroke:#C62828,color:#333
    classDef support fill:#F3E5F5,stroke:#7B1FA2,color:#333
    classDef drained fill:#ECEFF1,stroke:#546E7A,color:#333,stroke-dasharray: 5 5
    class Presentation,Application,Domain,Infrastructure,Data layer
    class AppApi boundary
    class Bootstrap bootstrap
    class Runtime support
    class EmptyLegacy drained
