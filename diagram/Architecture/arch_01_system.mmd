    classDef extStyle fill:#F3E5F5,stroke:#7B1FA2,color:#333,stroke-width:2px
    classDef rtStyle fill:#E0F7FA,stroke:#00695C,color:#333,stroke-width:2px
    class Browser clientStyle
    class Adonis serverStyle
    class PG,Mongo,Redis dbStyle
    class OAuth extStyle
    class WS rtStyle


