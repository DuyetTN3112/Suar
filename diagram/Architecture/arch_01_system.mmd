%% Architecture Diagram: System Overview
%% Updated 2026-04-29 from current backend refactor context.

flowchart TD
    subgraph client["Client Layer"]
        Browser["Browser\nSvelte + Inertia"]
        UserSurface["User workspace\nroot routes"]
        AdminSurface["System Admin\n/admin/*"]
        OrgSurface["Organization Admin\n/org/*"]
    end

    subgraph server["AdonisJS Application Server"]
        Http["Routes + Middleware + Controllers"]
        Actions["Action Layer\nCQRS commands/queries\nmodule public APIs"]
        Domain["Domain Layer\nentities, formulas, policies, rules"]
        Infra["Infrastructure Layer\nrepositories, mappers, cache/logger adapters"]
        Events["Events + Listeners\nactivity, audit, notification, cache invalidation"]
    end

    subgraph data["Data Layer"]
        PG[("PostgreSQL\ncore business data")]
        Mongo[("MongoDB\naudit_logs\nnotifications\nuser_activity_logs")]
        Redis[("Redis\nsessions, locks, app cache")]
    end

    subgraph external["External Runtime"]
        OAuth["OAuth Providers\nGoogle + GitHub"]
        Realtime["Transmit / realtime\nconfigured with transport=null"]
    end

    Browser --> UserSurface
    Browser --> AdminSurface
    Browser --> OrgSurface
    UserSurface --> Http
    AdminSurface --> Http
    OrgSurface --> Http

    Http --> Actions
    Actions --> Domain
    Actions --> Infra
    Infra --> PG
    Infra --> Mongo
    Infra --> Redis

    Actions --> Events
    Events --> Actions
    Events --> Infra
    Events -.-> Realtime

    Http --> OAuth
    OAuth --> Http

    classDef clientStyle fill:#E3F2FD,stroke:#1565C0,color:#333,stroke-width:2px
    classDef serverStyle fill:#FFF9C4,stroke:#F57F17,color:#333,stroke-width:2px
    classDef dataStyle fill:#E8F5E9,stroke:#2E7D32,color:#333,stroke-width:2px
    classDef extStyle fill:#F3E5F5,stroke:#7B1FA2,color:#333,stroke-width:2px
    class Browser,UserSurface,AdminSurface,OrgSurface clientStyle
    class Http,Actions,Domain,Infra,Events serverStyle
    class PG,Mongo,Redis dataStyle
    class OAuth,Realtime extStyle
