    %% ══════════════════════════════════════════════
    %% ORM Model Relationships (existing)
    %% ══════════════════════════════════════════════

    User "1" --> "*" UserOAuthProvider : has
    User "1" --> "*" RememberMeToken : has tokens
    User "1" --> "*" OrganizationUser : joins
    User "1" --> "0..1" Organization : belongsTo (current_organization)
    Organization "1" --> "*" OrganizationUser : has members
    Organization "1" --> "*" Project : contains
    User "1" --> "*" ProjectMember : participates
    Project "1" --> "*" ProjectMember : has members
    Project "1" --> "*" ProjectAttachment : has files
    User "1" --> "*" ProjectAttachment : uploads

    %% ══════════════════════════════════════════════
    %% 🏛️ Clean Architecture Relationships
    %% ══════════════════════════════════════════════

    %% Domain Mapper ↔ Domain Entity
    UserDomainMapper ..> UserEntity : creates / exports
    OrganizationDomainMapper ..> OrganizationEntity : creates / exports
    ProjectDomainMapper ..> ProjectEntity : creates / exports

    %% Repository Interface ← Implementation (implements)
    IUserRepository <|.. UserRepositoryImpl
    IOrganizationRepository <|.. OrganizationRepositoryImpl
    IProjectRepository <|.. ProjectRepositoryImpl

    %% Infra Mapper: ORM Model → Domain Entity
    UserInfraMapper ..> User : reads ORM
    UserInfraMapper ..> UserEntity : produces
    OrganizationInfraMapper ..> Organization : reads ORM
    OrganizationInfraMapper ..> OrganizationEntity : produces
    ProjectInfraMapper ..> Project : reads ORM
    ProjectInfraMapper ..> ProjectEntity : produces

    %% Repository Impl uses Infra Mapper
    UserRepositoryImpl ..> UserInfraMapper : uses
    OrganizationRepositoryImpl ..> OrganizationInfraMapper : uses
    ProjectRepositoryImpl ..> ProjectInfraMapper : uses

    %% Application Mapper: Domain Entity ↔ Response DTO
    UserApplicationMapper ..> UserEntity : reads
    UserApplicationMapper ..> UserDetailResponseDTO : produces
    UserApplicationMapper ..> UserListItemResponseDTO : produces
    UserApplicationMapper ..> UserProfileResponseDTO : produces
    UserApplicationMapper ..> UserSummaryResponseDTO : produces

    OrganizationApplicationMapper ..> OrganizationEntity : reads
    OrganizationApplicationMapper ..> OrganizationDetailResponseDTO : produces
    OrganizationApplicationMapper ..> OrganizationListItemResponseDTO : produces
    OrganizationApplicationMapper ..> OrganizationSummaryResponseDTO : produces

    ProjectApplicationMapper ..> ProjectEntity : reads
    ProjectApplicationMapper ..> ProjectDetailResponseDTO : produces
    ProjectApplicationMapper ..> ProjectListItemResponseDTO : produces
    ProjectApplicationMapper ..> ProjectSummaryResponseDTO : produces

    note for User "OAuth only — NO email/password auth.
    auth_method CHECK ('google','github').
    ⚡ = leaked static method (should → Repository)."
    note for RememberMeToken "Framework-managed by @adonisjs/auth
    DbRememberMeTokensProvider.
    No custom model file exists."
    note for ProjectAttachment "No file_size or mime_type columns.
    Only file_name + file_path stored."
    note for UserEntity "🏛️ Pure domain entity (app/domain/users/entities/).
    Business logic: canChangeRoleOf, canDeactivate, canApproveUser.
    Framework-independent — NO AdonisJS imports."
    note for OrganizationEntity "🏛️ Pure domain entity (app/domain/organizations/entities/).
    State queries: isPartner, isDeleted, hasCustomRoles."
    note for ProjectEntity "🏛️ Pure domain entity (app/domain/projects/entities/).
    State queries: isActive, isCompleted, isPublic, allowsFreelancers."
    note for IUserRepository "🏛️ Domain contract (app/domain/users/repositories/).
    Implemented by UserRepositoryImpl in infra layer."


