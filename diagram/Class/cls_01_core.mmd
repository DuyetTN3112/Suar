
%% Class Diagram: Core Domain (User, Org, Project)
%% Source: app/models/user.ts, organization.ts, organization_user.ts,
%%         project.ts, project_member.ts, project_attachment.ts,
%%         user_o_auth_provider.ts
%%         + Clean Architecture DDD layers:
%%         app/domain/{users,organizations,projects}/
%%         app/infra/{users,organizations,projects}/
%%         app/actions/{users,organizations,projects}/
%% Scope: Columns match @column decorators exactly. Methods show actual
%%         static/instance methods in model (not business logic in Commands).
%%         ⚠️ = planned in SQL v3 but not yet in model code.
%%         Leaked static methods annotated — should migrate to Repository layer.
%%         🏛️ = Clean Architecture + DDD layer classes.
classDiagram

    %% ══════════════════════════════════════════════
    %% ORM Models (Infrastructure — Lucid BaseModel)
    %% ══════════════════════════════════════════════

    class User {
        +UUID id PK
        +String username UK
        +String email UK
        +String status : active | inactive | suspended
        +String system_role : superadmin | system_admin | registered_user
        +UUID current_organization_id FK
        +String auth_method : google | github
        +String avatar_url
        +Text bio
        +String phone
        +Text address
        +String timezone
        +String language
        +Boolean is_freelancer
        +Decimal freelancer_rating
        +Integer freelancer_completed_tasks_count
        +SmallInt ranking_priority : 1-3
        +Boolean is_verified_badge
        +JSONB profile_settings
        +JSONB trust_data
        +JSONB credibility_data
        +DateTime deleted_at
        +DateTime created_at
        +DateTime updated_at
        --
        +get isAdmin() Boolean
        +$findActiveOrFail(userId, trx?)⚡
        +$isActive(userId, trx?)⚡
        +$isFreelancer(userId, trx?)⚡
        +$isSuperadmin(userId, trx?)⚡
        +$findNotDeletedOrFail(userId, trx?)⚡
        +$getSystemRoleName(userId, trx?)⚡
        +$isSystemAdmin(userId, trx?)⚡
    }

    class UserOAuthProvider {
        +UUID id PK
        +UUID user_id FK
        +String provider : google | github
        +String provider_id UK
        +String email
        +String access_token
        +String refresh_token
        +DateTime created_at
        +DateTime updated_at
    }

    class RememberMeToken {
        +SERIAL id PK
        +UUID tokenable_id FK
        +String hash
        +DateTime expires_at
        +DateTime created_at
        +DateTime updated_at
    }

    class Organization {
        +UUID id PK
        +String name
        +String slug UK
        +Text description
        +String logo
        +String website
        +String plan : free | starter | professional | enterprise
        +UUID owner_id FK
        +JSONB custom_roles
        +String partner_type : gold | silver | bronze
        +DateTime partner_verified_at
        +UUID partner_verified_by FK
        +Text partner_verification_proof
        +DateTime partner_expires_at
        +Boolean partner_is_active
        +DateTime deleted_at
        +DateTime created_at
        +DateTime updated_at
        --
        +$findActiveOrFail(orgId, trx?)⚡
        +$existsActive(orgId, trx?)⚡
        +$slugExists(slug, trx?)⚡
        +$getUniqueSlug(base, trx?)⚡
        +$countActiveProjects(orgId, trx?)⚡
        +$paginateByUser(userId, page, trx?)⚡
    }

    class OrganizationUser {
        +UUID organization_id PK_FK
        +UUID user_id PK_FK
        +String org_role : org_owner | org_admin | org_member
        +String status : pending | approved | rejected
        +UUID invited_by FK
        +DateTime created_at
        +DateTime updated_at
        --
        +$findMembership(orgId, userId, trx?)⚡
        +$findMembershipOrFail(orgId, userId, trx?)⚡
        +$isApprovedMember(orgId, userId, trx?)⚡
        +$isOrgAdminOrOwner(orgId, userId, trx?)⚡
        +$validateAllApprovedMembers(orgId, userIds, trx?)⚡
        +$findApprovedMemberOrFail(orgId, userId, trx?)⚡
    }

    class Project {
        +UUID id PK
        +UUID creator_id FK
        +String name
        +Text description
        +UUID organization_id FK
        +DateTime start_date
        +DateTime end_date
        +String status : pending | in_progress | completed | cancelled
        +Decimal budget
        +UUID manager_id FK
        +UUID owner_id FK
        +String visibility : public | private | team
        +Boolean allow_freelancer
        +Boolean approval_required_for_members
        +JSONB tags
        +JSONB custom_roles
        +DateTime deleted_at
        +DateTime created_at
        +DateTime updated_at
        --
        +$findActiveOrFail(projectId, trx?)⚡
        +$findActiveForUpdate(projectId, trx?)⚡
        +$validateBelongsToOrg(projectId, orgId, trx?)⚡
        +$findIdsByOrganization(orgId, trx?)⚡
    }

    class ProjectMember {
        +UUID project_id PK_FK
        +UUID user_id PK_FK
        +String project_role : project_owner | project_manager | project_member | project_viewer
        +DateTime created_at
        --
        +$findMember(projectId, userId, trx?)⚡
        +$findMemberOrFail(projectId, userId, trx?)⚡
        +$deleteMember(projectId, userId, trx?)⚡
        +$isProjectManagerOrOwner(projectId, userId, trx?)⚡
    }

    class ProjectAttachment {
        +UUID id PK
        +UUID project_id FK
        +String file_name
        +String file_path
        +UUID uploaded_by FK
        +DateTime created_at
        +DateTime updated_at
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Domain Entities (app/domain/*/entities/)
    %% Pure TypeScript, NO framework dependencies
    %% ══════════════════════════════════════════════

    class UserEntity {
        <<Domain Entity>>
        +String id
        +String username
        +String email
        +UserStatus status
        +UserSystemRole systemRole
        +String currentOrganizationId
        +UserAuthMethod authMethod
        +String avatarUrl
        +String bio
        +String phone
        +String address
        +String timezone
        +String language
        +Boolean isFreelancer
        +Number freelancerRating
        +Number freelancerCompletedTasksCount
        +UserProfileSettings profileSettings
        +UserTrustData trustData
        +UserCredibilityData credibilityData
        +Date deletedAt
        +Date createdAt
        +Date updatedAt
        --
        +get isActive() Boolean
        +get isAdmin() Boolean
        +get isSuperadmin() Boolean
        +get isDeleted() Boolean
        +canChangeRoleOf(targetUserId, newRole) PolicyResult
        +canDeactivate(targetUserId) PolicyResult
        +canApproveUser(hasPermission, status) PolicyResult
        +$validateSystemRole(role) PolicyResult
    }

    class OrganizationEntity {
        <<Domain Entity>>
        +String id
        +String name
        +String slug
        +String description
        +String logo
        +String website
        +String plan
        +String ownerId
        +CustomRoleDefinition[] customRoles
        +String partnerType
        +Date partnerVerifiedAt
        +String partnerVerifiedBy
        +String partnerVerificationProof
        +Date partnerExpiresAt
        +Boolean partnerIsActive
        +Date deletedAt
        +Date createdAt
        +Date updatedAt
        --
        +get isPartner() Boolean
        +get isDeleted() Boolean
        +get hasCustomRoles() Boolean
    }

    class ProjectEntity {
        <<Domain Entity>>
        +String id
        +String creatorId
        +String name
        +String description
        +String organizationId
        +Date startDate
        +Date endDate
        +ProjectStatus status
        +String budget
        +String managerId
        +String ownerId
        +ProjectVisibility visibility
        +Boolean allowFreelancer
        +Boolean approvalRequiredForMembers
        +unknown[] tags
        +CustomRoleDefinition[] customRoles
        +Date deletedAt
        +Date createdAt
        +Date updatedAt
        --
        +get isActive() Boolean
        +get isCompleted() Boolean
        +get isDeleted() Boolean
        +get isPublic() Boolean
        +get allowsFreelancers() Boolean
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Domain Mappers (app/domain/*/mapper/)
    %% Pure TypeScript — props ↔ Domain Entity
    %% ══════════════════════════════════════════════

    class UserDomainMapper {
        <<Domain Mapper>>
        +$toEntity(props: UserEntityProps) UserEntity
        +$toProps(entity: UserEntity) UserEntityProps
    }

    class OrganizationDomainMapper {
        <<Domain Mapper>>
        +$toEntity(props: OrganizationEntityProps) OrganizationEntity
        +$toProps(entity: OrganizationEntity) OrganizationEntityProps
    }

    class ProjectDomainMapper {
        <<Domain Mapper>>
        +$toEntity(props: ProjectEntityProps) ProjectEntity
        +$toProps(entity: ProjectEntity) ProjectEntityProps
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Repository Interfaces (app/domain/*/repositories/)
    %% Contracts — implemented by infra layer
    %% ══════════════════════════════════════════════

    class IUserRepository {
        <<interface>>
        +findById(id) Promise~UserEntity|null~
        +findActiveOrFail(id) Promise~UserEntity~
        +findNotDeletedOrFail(id) Promise~UserEntity~
        +findByIds(ids, fields?) Promise~UserEntity[]~
        +findByOrganization(orgId) Promise~UserEntity[]~
        +findWithOrganizations(id) Promise~UserEntity~
        +isActive(id) Promise~Boolean~
        +isFreelancer(id) Promise~Boolean~
        +isSuperadmin(id) Promise~Boolean~
        +isSystemAdmin(id) Promise~Boolean~
        +getSystemRoleName(id) Promise~String|null~
    }

    class IOrganizationRepository {
        <<interface>>
        +findById(id) Promise~OrganizationEntity|null~
        +findBySlug(slug) Promise~OrganizationEntity|null~
        +findByOwnerId(ownerId) Promise~OrganizationEntity[]~
        +findNotDeletedOrFail(id) Promise~OrganizationEntity~
    }

    class IProjectRepository {
        <<interface>>
        +findById(id) Promise~ProjectEntity|null~
        +findByOrganization(orgId) Promise~ProjectEntity[]~
        +findByCreator(creatorId) Promise~ProjectEntity[]~
        +findByManager(managerId) Promise~ProjectEntity[]~
        +findNotDeletedOrFail(id) Promise~ProjectEntity~
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Infrastructure Mappers (app/infra/*/mapper/)
    %% ORM Model ↔ Domain Entity
    %% ══════════════════════════════════════════════

    class UserInfraMapper {
        <<Infra Mapper>>
        +$toDomain(model: User) UserEntity
        +$toOrm(entity: Partial~UserEntityProps~) Record
    }

    class OrganizationInfraMapper {
        <<Infra Mapper>>
        +$toDomain(model: Organization) OrganizationEntity
        +$toOrm(entity: Partial~OrganizationEntityProps~) Record
    }

    class ProjectInfraMapper {
        <<Infra Mapper>>
        +$toDomain(model: Project) ProjectEntity
        +$toOrm(entity: Partial~ProjectEntityProps~) Record
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Repository Implementations (app/infra/*/repositories/)
    %% Implement interfaces using Lucid ORM
    %% ══════════════════════════════════════════════

    class UserRepositoryImpl {
        <<Infra Repository>>
        +findById(id) Promise~UserEntity|null~
        +findActiveOrFail(id) Promise~UserEntity~
        +findNotDeletedOrFail(id) Promise~UserEntity~
        +findByIds(ids, fields?) Promise~UserEntity[]~
        +findByOrganization(orgId) Promise~UserEntity[]~
        +findWithOrganizations(id) Promise~UserEntity~
        +isActive(id) Promise~Boolean~
        +isFreelancer(id) Promise~Boolean~
        +isSuperadmin(id) Promise~Boolean~
        +isSystemAdmin(id) Promise~Boolean~
        +getSystemRoleName(id) Promise~String|null~
    }

    class OrganizationRepositoryImpl {
        <<Infra Repository>>
        +findById(id) Promise~OrganizationEntity|null~
        +findBySlug(slug) Promise~OrganizationEntity|null~
        +findByOwnerId(ownerId) Promise~OrganizationEntity[]~
        +findNotDeletedOrFail(id) Promise~OrganizationEntity~
    }

    class ProjectRepositoryImpl {
        <<Infra Repository>>
        +findById(id) Promise~ProjectEntity|null~
        +findByOrganization(orgId) Promise~ProjectEntity[]~
        +findByCreator(creatorId) Promise~ProjectEntity[]~
        +findByManager(managerId) Promise~ProjectEntity[]~
        +findNotDeletedOrFail(id) Promise~ProjectEntity~
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Application Mappers (app/actions/*/mapper/)
    %% Request DTO → Domain Entity, Domain Entity → Response DTO
    %% ══════════════════════════════════════════════

    class UserApplicationMapper {
        <<Application Mapper>>
        +$fromRegisterDTO(dto) Object
        +$fromUpdateProfileDTO(dto) Object
        +$fromUpdateDetailsDTO(dto) Object
        +$toDetailResponse(entity) UserDetailResponseDTO
        +$toListItemResponse(entity) UserListItemResponseDTO
        +$toProfileResponse(entity) UserProfileResponseDTO
        +$toSummaryResponse(entity) UserSummaryResponseDTO
    }

    class OrganizationApplicationMapper {
        <<Application Mapper>>
        +$fromCreateDTO(dto) Object
        +$toDetailResponse(entity) OrganizationDetailResponseDTO
        +$toListItemResponse(entity) OrganizationListItemResponseDTO
        +$toSummaryResponse(entity) OrganizationSummaryResponseDTO
    }

    class ProjectApplicationMapper {
        <<Application Mapper>>
        +$fromCreateDTO(dto) Object
        +$toDetailResponse(entity) ProjectDetailResponseDTO
        +$toListItemResponse(entity) ProjectListItemResponseDTO
        +$toSummaryResponse(entity) ProjectSummaryResponseDTO
    }

