
%% Class Diagram: Task Core Domain
%% Source: app/models/task.ts, task_status.ts, task_workflow_transition.ts,
%%         task_version.ts, task_assignment.ts, task_application.ts
%%         + Clean Architecture DDD layers:
%%         app/domain/tasks/
%%         app/infra/tasks/
%%         app/actions/tasks/
%% Scope: Columns match @column decorators exactly.
%%         ⚡ = leaked static method (should → Repository layer).
%%         No created_at/updated_at on TaskAssignment (uses assigned_at).
%%         No created_at/updated_at on TaskApplication (uses applied_at).
%%         Phase 4: TaskStatus + TaskWorkflowTransition added.
%%         🏛️ = Clean Architecture + DDD layer classes.
classDiagram

    %% ══════════════════════════════════════════════
    %% ORM Models (Infrastructure — Lucid BaseModel)
    %% ══════════════════════════════════════════════

    class Task {
        +UUID id PK
        +String title
        +Text description
        +String status : DEPRECATED (use task_status_id)
        +UUID task_status_id FK : Phase 4
        +String label : bug | feature | enhancement | documentation
        +String priority : low | medium | high | urgent
        +String difficulty : easy | medium | hard | expert
        +UUID assigned_to FK
        +UUID creator_id FK
        +UUID updated_by FK
        +DateTime due_date
        +UUID parent_task_id FK
        +Decimal estimated_time
        +Decimal actual_time
        +UUID organization_id FK
        +UUID project_id FK
        +String task_visibility : internal | external | all
        +DateTime application_deadline
        +Decimal estimated_budget
        +Integer external_applications_count
        +Integer sort_order
        +DateTime deleted_at
        +DateTime created_at
        +DateTime updated_at
        --
        +serialize() override
        +$countIncompleteByProject(projectId, trx?)⚡
        +$reassignByUser(projectId, from, to, trx?)⚡
        +$unassignByUserInProjects(pIds, userId, trx?)⚡
        +$getTasksSummaryByProject(projectId, trx?)⚡
        +$countByAssignees(projectId, userIds?, trx?)⚡
        +$countByProjectIds(projectIds, trx?)⚡
    }

    class TaskStatusModel {
        +UUID id PK
        +UUID organization_id FK
        +String name
        +String slug UK(org, slug)
        +String category : todo | in_progress | done | cancelled
        +String color : hex
        +String icon
        +String description
        +Integer sort_order
        +Boolean is_default
        +Boolean is_system
        +DateTime deleted_at
        +DateTime created_at
        +DateTime updated_at
        --
        +$findByOrganization(orgId, trx?)
        +$findDefault(orgId, trx?)
        +$findBySlug(orgId, slug, trx?)
        +$slugExists(orgId, slug, excludeId?, trx?)
    }

    class TaskWorkflowTransition {
        +UUID id PK
        +UUID organization_id FK
        +UUID from_status_id FK
        +UUID to_status_id FK
        +JSONB conditions
        +DateTime created_at
        --
        +$findByOrganization(orgId, trx?)
        +$findFromStatus(orgId, fromId, trx?)
        +$deleteByOrganization(orgId, trx?)
    }

    class TaskVersion {
        +UUID id PK
        +UUID task_id FK
        +String title
        +Text description
        +String status
        +String label
        +String priority
        +String difficulty
        +UUID assigned_to FK
        +UUID changed_by FK
        +DateTime changed_at
        --
        +$createSnapshot(data, trx?)⚡
    }

    class TaskAssignment {
        +UUID id PK
        +UUID task_id FK
        +UUID assignee_id FK
        +UUID assigned_by FK
        +String assignment_type : member | freelancer | volunteer
        +String assignment_status : active | completed | cancelled
        +Decimal estimated_hours
        +Decimal actual_hours
        +Integer progress_percentage
        +Text completion_notes
        +UUID verified_by FK
        +DateTime verified_at
        +DateTime assigned_at ⟵ autoCreate (no created_at)
        +DateTime completed_at
        --
        +$findActiveWithDetails(assignmentId, trx?)⚡
        +$cancelAssignment(assignmentId, notes, trx?)⚡
        +$findProjectManagerIds(projectId, exclude?, trx?)⚡
    }

    class TaskApplication {
        +UUID id PK
        +UUID task_id FK
        +UUID applicant_id FK
        +String application_status : pending | approved | rejected | withdrawn
        +String application_source : public_listing | invitation | referral
        +Text message
        +Decimal expected_rate
        +JSONB portfolio_links
        +UUID reviewed_by FK
        +String rejection_reason
        +DateTime applied_at ⟵ autoCreate (no created_at)
        +DateTime reviewed_at
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Domain Entity (app/domain/tasks/entities/)
    %% Pure TypeScript, NO framework dependencies
    %% ══════════════════════════════════════════════

    class TaskEntity {
        <<Domain Entity>>
        +String id
        +String title
        +String description
        +TaskStatus status
        +String taskStatusId
        +TaskLabel label
        +TaskPriority priority
        +TaskDifficulty difficulty
        +String assignedTo
        +String creatorId
        +String updatedBy
        +Date dueDate
        +String parentTaskId
        +Number estimatedTime
        +Number actualTime
        +String organizationId
        +String projectId
        +TaskVisibility taskVisibility
        +Date applicationDeadline
        +Number estimatedBudget
        +Number externalApplicationsCount
        +Number sortOrder
        +Date deletedAt
        +Date createdAt
        +Date updatedAt
        --
        +get isOverdue() Boolean
        +get isAssigned() Boolean
        +get isSubtask() Boolean
        +get isCompleted() Boolean
        +get isCancelled() Boolean
        +get isDeleted() Boolean
        +get isExternal() Boolean
        +get belongsToProject() Boolean
        +get hasEstimatedBudget() Boolean
        +get isApplicationOpen() Boolean
        +get timeEfficiency() Number|null
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Domain Mapper (app/domain/tasks/mapper/)
    %% Pure TypeScript — props ↔ Domain Entity
    %% ══════════════════════════════════════════════

    class TaskDomainMapper {
        <<Domain Mapper>>
        +$toEntity(props: TaskEntityProps) TaskEntity
        +$toProps(entity: TaskEntity) TaskEntityProps
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Repository Interface (app/domain/tasks/repositories/)
    %% Contract — implemented by infra layer
    %% ══════════════════════════════════════════════

    class ITaskRepository {
        <<interface>>
        +findById(id) Promise~TaskEntity|null~
        +findByOrganization(orgId) Promise~TaskEntity[]~
        +findByProject(projectId) Promise~TaskEntity[]~
        +findByAssignee(userId) Promise~TaskEntity[]~
        +findByCreator(userId) Promise~TaskEntity[]~
        +findNotDeletedOrFail(id) Promise~TaskEntity~
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Infrastructure Mapper (app/infra/tasks/mapper/)
    %% ORM Model ↔ Domain Entity
    %% ══════════════════════════════════════════════

    class TaskInfraMapper {
        <<Infra Mapper>>
        +$toDomain(model: Task) TaskEntity
        +$toOrm(entity: Partial~TaskEntityProps~) Record
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Repository Implementation (app/infra/tasks/repositories/)
    %% Implements interface using Lucid ORM
    %% ══════════════════════════════════════════════

    class TaskRepositoryImpl {
        <<Infra Repository>>
        +findById(id) Promise~TaskEntity|null~
        +findByOrganization(orgId) Promise~TaskEntity[]~
        +findByProject(projectId) Promise~TaskEntity[]~
        +findByAssignee(userId) Promise~TaskEntity[]~
        +findByCreator(userId) Promise~TaskEntity[]~
        +findNotDeletedOrFail(id) Promise~TaskEntity~
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Application Mapper (app/actions/tasks/mapper/)
    %% Request DTO → Domain Entity, Domain Entity → Response DTO
    %% ══════════════════════════════════════════════

    class TaskApplicationMapper {
        <<Application Mapper>>
        +$fromCreateDTO(dto) Object
        +$fromUpdateDTO(dto) Record
        +$toDetailResponse(entity) TaskDetailResponseDTO
        +$toListItemResponse(entity) TaskListItemResponseDTO
        +$toSummaryResponse(entity) TaskSummaryResponseDTO
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Response DTOs (app/actions/tasks/dtos/response/)
    %% ══════════════════════════════════════════════

    class TaskDetailResponseDTO {
        <<Response DTO>>
        +String id
        +String title
        +String description
        +String status
        +String taskStatusId
        +String label
        +String priority
        +Date createdAt
    }
    class TaskListItemResponseDTO {
        <<Response DTO>>
        +String id
        +String title
        +String status
        +String priority
        +Number sortOrder
    }
    class TaskSummaryResponseDTO {
        <<Response DTO>>
        +String id
        +String title
        +String status
        +String priority
    }

    %% ══════════════════════════════════════════════
    %% ORM Model Relationships (existing)
    %% ══════════════════════════════════════════════

    Task "1" --> "*" TaskVersion : versioned by
    Task "1" --> "*" TaskAssignment : assigned via
    Task "1" --> "*" TaskApplication : receives
    Task "0..1" --> "*" Task : parent of (subtasks)
    Task "*" --> "1" TaskStatusModel : has status (Phase 4)
    TaskStatusModel "1" --> "*" TaskWorkflowTransition : from_status
    TaskStatusModel "1" --> "*" TaskWorkflowTransition : to_status

    %% ══════════════════════════════════════════════
    %% 🏛️ Clean Architecture Relationships
    %% ══════════════════════════════════════════════

    %% Domain Mapper ↔ Domain Entity
    TaskDomainMapper ..> TaskEntity : creates / exports

    %% Repository Interface ← Implementation (implements)
    ITaskRepository <|.. TaskRepositoryImpl

    %% Infra Mapper: ORM Model → Domain Entity
    TaskInfraMapper ..> Task : reads ORM
    TaskInfraMapper ..> TaskEntity : produces

    %% Repository Impl uses Infra Mapper
    TaskRepositoryImpl ..> TaskInfraMapper : uses

    %% Application Mapper: Domain Entity ↔ Response DTO
    TaskApplicationMapper ..> TaskEntity : reads
    TaskApplicationMapper ..> TaskDetailResponseDTO : produces
    TaskApplicationMapper ..> TaskListItemResponseDTO : produces
    TaskApplicationMapper ..> TaskSummaryResponseDTO : produces

    note for Task "task_visibility controls Marketplace visibility.
    ⚡ = leaked static → should be in Repository.
    Assignment does NOT change task status."
    note for TaskAssignment "NO created_at/updated_at columns.
    Uses assigned_at (autoCreate) instead.
    verified_by/verified_at exist but NEVER SET by code."
    note for TaskApplication "NO created_at/updated_at columns.
    Uses applied_at (autoCreate) instead.
    application_deadline NOT enforced by ApplyForTaskCommand."
    note for TaskVersion "Stores FULL snapshot of task fields.
    Only created by UpdateTaskCommand (not create/status)."
    note for TaskEntity "🏛️ Pure domain entity (app/domain/tasks/entities/).
    Rich business logic: isOverdue, isApplicationOpen, timeEfficiency.
    Framework-independent — NO AdonisJS imports."
    note for ITaskRepository "🏛️ Domain contract (app/domain/tasks/repositories/).
    Implemented by TaskRepositoryImpl in infra layer."

