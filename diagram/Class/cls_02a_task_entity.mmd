%% Class Diagram: Task Aggregate Detail
%% Scope: Task model, domain entity, mappers, and response DTOs only.

classDiagram
    class Task {
        +UUID id
        +String title
        +Text description
        +String status : legacy
        +UUID task_status_id
        +String label
        +String priority
        +String difficulty
        +UUID assigned_to
        +UUID creator_id
        +UUID organization_id
        +UUID project_id
        +String task_visibility
        +DateTime due_date
        +Integer sort_order
        +DateTime deleted_at
        +DateTime created_at
        +DateTime updated_at
    }

    class TaskEntity {
        <<Domain Entity>>
        +String id
        +String title
        +String description
        +TaskStatus status
        +String taskStatusId
        +TaskLabel label
        +TaskPriority priority
        +TaskDifficulty difficulty
        +String assignedTo
        +String creatorId
        +String organizationId
        +String projectId
        +TaskVisibility taskVisibility
        +Date dueDate
        +Number sortOrder
        --
        +isOverdue() Boolean
        +isAssigned() Boolean
        +isCompleted() Boolean
        +isApplicationOpen() Boolean
    }

    class TaskDomainMapper {
        <<Domain Mapper>>
        +toEntity(props) TaskEntity
        +toProps(entity) TaskEntityProps
    }

    class TaskInfraMapper {
        <<Infra Mapper>>
        +toDomain(model: Task) TaskEntity
        +toOrm(entity: Partial~TaskEntityProps~) Record
    }

    class TaskApplicationMapper {
        <<Application Mapper>>
        +fromCreateDTO(dto) Object
        +fromUpdateDTO(dto) Record
        +toDetailResponse(entity) TaskDetailResponseDTO
        +toListItemResponse(entity) TaskListItemResponseDTO
        +toSummaryResponse(entity) TaskSummaryResponseDTO
    }

    class TaskDetailResponseDTO {
        <<Response DTO>>
        +String id
        +String title
        +String description
        +String status
        +String taskStatusId
        +String priority
    }

    class TaskListItemResponseDTO {
        <<Response DTO>>
        +String id
        +String title
        +String status
        +String priority
        +Number sortOrder
    }

    class TaskSummaryResponseDTO {
        <<Response DTO>>
        +String id
        +String title
        +String status
        +String priority
    }

    Task --> TaskEntity : mapped to domain
    TaskDomainMapper ..> TaskEntity : creates
    TaskInfraMapper ..> Task : reads ORM
    TaskInfraMapper ..> TaskEntity : produces
    TaskApplicationMapper ..> TaskEntity : reads
    TaskApplicationMapper ..> TaskDetailResponseDTO : produces
    TaskApplicationMapper ..> TaskListItemResponseDTO : produces
    TaskApplicationMapper ..> TaskSummaryResponseDTO : produces

    note for Task "task_status_id is the active status reference.
    status string remains as legacy mirror.
    project_id is required by the application layer."
    note for TaskEntity "Pure domain entity.
    No framework imports."
