        +Date deadline
        +isCompleted
        +isPending
        +isOverdue
        +canAddPeerReview
        +peerReviewProgress
    }

    class SkillReviewEntity {
        <<Domain Entity>>
        +String id
        +String reviewSessionId
        +String reviewerId
        +SkillReviewerType reviewerType
        +String skillId
        +String assignedLevelCode
        +String comment
        +isManagerReview
        +isPeerReview
    }

    ReviewSession "1" --> "*" SkillReview : contains
    ReviewSession --> ReviewSessionEntity : mapped to domain
    SkillReview --> SkillReviewEntity : mapped to domain

    note for ReviewSession "Manager and peer reviews run in parallel.
    confirm/dispute is a later step.
    Auto-created when task enters done category."
    note for ReviewSessionEntity "Pure domain entity.
    No framework imports."
