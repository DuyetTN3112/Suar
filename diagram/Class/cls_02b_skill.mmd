
%% Class Diagram: Skill Domain
%% Source: app/infra/skills/models/skill.ts,
%%         app/infra/users/models/user_skill.ts, app/infra/users/models/recruiter_bookmark.ts,
%%         app/infra/tasks/models/task_required_skill.ts
%% Scope: Columns match @column decorators exactly.
%%         Repository methods now live in app/infra/skills/repositories/skill_repository.ts.
%%         RecruiterBookmark: model + table exist but NO routes wired.
%%         NOTE: Skill has an action public API + infra repository, but no dedicated domain entity yet.
classDiagram
    class Skill {
        +UUID id PK
        +String category_code : technical | soft_skill | delivery
        +String display_type : spider_chart | list
        +String skill_code UK
        +String skill_name
        +Text description
        +String icon_url
        +Boolean is_active
        +Integer sort_order
        +DateTime created_at
        +DateTime updated_at
    }

    class UserSkill {
        +UUID id PK
        +UUID user_id FK
        +UUID skill_id FK
        +String level_code : beginner ~ master
        +String source : imported | reviewed
        +Integer total_reviews
        +Decimal avg_score
        +Decimal avg_percentage
        +DateTime last_reviewed_at
        +DateTime last_calculated_at
        +DateTime created_at
        +DateTime updated_at
        --
        +get hasBeenReviewed() Boolean
        +get displayScore() String
    }

    class TaskRequiredSkill {
        +UUID id PK
        +UUID task_id FK
        +UUID skill_id FK
        +String required_level_code : beginner ~ master
        +Boolean is_mandatory
        +DateTime created_at
    }

    class RecruiterBookmark {
        +UUID id PK
        +UUID recruiter_user_id FK
        +UUID talent_user_id FK
        +Text notes
        +String folder
        +Smallint rating : 1 ~ 5
        +DateTime created_at
        +DateTime updated_at
    }

    class SkillRepository {
        +activeSkills()
        +byCategory(categoryCode)
        +getSpiderChartSkillIds(trx?)
        +findActiveByIds(ids, trx?)
        +findByIds(ids, trx?)
        +findByUserAndSkill(userId, skillId)
        +getUserSkillsWithDetails(userId)
        +findUserSkillsWithSkill(userId, trx?)
    }

    %% Relationships
    Skill "1" --> "*" TaskRequiredSkill : tagged in
    Skill "1" --> "*" UserSkill : acquired by
    RecruiterBookmark ..> UserSkill : evaluated by

    note for RecruiterBookmark "Model + table exist but NO routes/controllers wired.
    Zero methods — completely passive entity."
    note for Skill "Lucid model only. Query methods moved to SkillRepository."
    note for SkillRepository "Read repository for Skill and UserSkill.
    Used by app/actions/skills public API and tests."
