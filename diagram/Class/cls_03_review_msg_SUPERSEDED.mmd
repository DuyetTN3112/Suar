
%% Class Diagram: Review & Messaging Domain
%% Source: app/models/review_session.ts, skill_review.ts, reverse_review.ts,
%%         flagged_review.ts, conversation.ts, conversation_participant.ts,
%%         message.ts
%% Scope: Columns match @column decorators exactly.
%%         ⚡ = leaked static method (should → Repository layer).
%%         ⚠️ = planned in SQL v3 but not yet in model code.
classDiagram
    class ReviewSession {
        +UUID id PK
        +UUID task_assignment_id FK
        +UUID reviewee_id FK
        +String status : pending | in_progress | completed | disputed
        +Boolean manager_review_completed
        +Integer peer_reviews_count
        +Integer required_peer_reviews
        +JSONB confirmations
        +DateTime deadline
        +DateTime completed_at
        +DateTime created_at
        +DateTime updated_at
    }

    class SkillReview {
        +UUID id PK
        +UUID review_session_id FK
        +UUID reviewer_id FK
        +String reviewer_type : manager | peer
        +UUID skill_id FK
        +String assigned_level_code : beginner ~ master
        +Text comment
        +DateTime created_at
        +DateTime updated_at
        --
        +$countCompletedByReviewer(userId, trx?)⚡
        +$countConfirmedByReviewer(userId, trx?)⚡
        +$countDisputedByReviewer(userId, trx?)⚡
        +$calculateSkillAvgPercentage(userId, skillId, trx?)⚡
    }

    class ReverseReview {
        +UUID id PK
        +UUID review_session_id FK
        +UUID reviewer_id FK
        +String target_type : peer | manager | project | organization
        +UUID target_id FK
        +Smallint rating : 1 ~ 5
        +Text comment
        +Boolean is_anonymous
        +DateTime created_at
    }

    class FlaggedReview {
        +UUID id PK
        +UUID skill_review_id FK
        +String flag_type : sudden_spike | mutual_high | bulk_same_level | frequency_anomaly | new_account_high | ip_collusion
        +String severity : low | medium | high | critical
        +String status : pending | reviewed | dismissed | confirmed
        +DateTime detected_at
        +UUID reviewed_by FK
        +DateTime reviewed_at
        +Text notes
        +DateTime created_at
        +DateTime updated_at
    }

    class Conversation {
        +UUID id PK
        +String title
        +UUID organization_id FK (nullable)
        +UUID task_id FK (nullable, dead code)
        +UUID last_message_id FK
        +DateTime last_message_at
        +DateTime deleted_at
        +DateTime created_at
        +DateTime updated_at
        --
        +$findWithParticipantOrFail(convId, userId, trx?)⚡
        +$findWithParticipant(convId, userId, trx?)⚡
        +$paginateByUser(userId, opts, trx?)⚡
        +$findIdsByOrganization(orgId, trx?)⚡
        +$findDirectBetween(userId1, userId2)⚡
        +$findGroupWithParticipants(participantIds)⚡
    }

    class ConversationParticipant {
        +UUID id PK
        +UUID conversation_id FK
        +UUID user_id FK
        --
        +$createBatch(convId, userIds, trx?)⚡
        +$isParticipant(convId, userId, trx?)⚡
        +$countByConversation(convId, trx?)⚡
        +$getParticipantIds(convId, trx?)⚡
        +$removeByUserInConversations(userId, convIds, trx?)⚡
    }

    class Message {
        +UUID id PK
        +UUID conversation_id FK
        +UUID sender_id FK
        +Text message
        +String send_status : sending | sent | failed
        +Boolean is_recalled
        +DateTime recalled_at
        +String recall_scope : self | all (nullable)
        +DateTime read_at
        +DateTime created_at
        +DateTime updated_at
        --
        +@computed isEffectivelyRecalled() Boolean
        +@computed isRecalledForEveryone() Boolean
        +@computed summary() Object
        +toJSON() override
        +$markAllAsReadInConversation(convId, userId, trx?)⚡
        +$markSpecificAsRead(convId, msgIds, userId, trx?)⚡
        +$countUnreadInConversation(convId, userId, trx?)⚡
        +$countUnreadBatch(convIds, userId, trx?)⚡
        +$getLastMessageInConversation(convId, userId, trx?)⚡
        +$getLastMessagesBatch(convIds, userId, trx?)⚡
        +$paginateByConversation(convId, userId, opts, trx?)⚡
        +$getParticipantsBatch(convIds, trx?)⚡
    }

    %% Review relationships
    ReviewSession "1" --> "*" SkillReview : contains
    ReviewSession "1" --> "*" ReverseReview : has reverse
    SkillReview "1" --> "0..1" FlaggedReview : may be flagged

    %% Review cross-references
    ReviewSession ..> TaskAssignment : triggered by (task_assignment_id)

    %% Messaging relationships
    Conversation "1" --> "*" ConversationParticipant : has
    Conversation "1" --> "*" Message : contains

    %% Messaging cross-references
    Conversation ..> Organization : scoped to (nullable)

    note for ReviewSession "Zero methods — fully driven by Commands.
    Reviews are PARALLEL (manager + peers independently).
    deadline = auto-set to NOW()+14 days on creation."
    note for ReverseReview "Only created_at — NO updated_at.
    Polymorphic target via target_type + target_id.
    Updates credibility_data of reviewer."
    note for FlaggedReview "'reviewed' status exists in CHECK but
    NEVER SET by any code (dead status).
    Only 3/6 flag_type patterns implemented."
    note for ConversationParticipant "Only 3 columns: id, conversation_id, user_id.
    NO last_read_at, NO timestamps.
    Read tracking via Message.read_at instead."
    note for Message "Messages created as 'sent' directly.
    No 'sending' state server-side.
    'failed' status unreachable.
    Transmit NOT wired (transport=null)."
    note for Conversation "task_id is dead code — exists in schema
    but never used by any controller/command."


