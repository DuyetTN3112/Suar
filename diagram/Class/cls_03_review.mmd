
%% Class Diagram: Review Domain
%% Source: app/models/review_session.ts, skill_review.ts, reverse_review.ts,
%%         flagged_review.ts
%%         + Clean Architecture DDD layers:
%%         app/domain/reviews/
%%         app/infra/reviews/
%%         app/actions/reviews/
%% Scope: Columns match @column decorators exactly.
%%         ⚡ = leaked static method (should → Repository layer).
%%         🏛️ = Clean Architecture + DDD layer classes.
classDiagram

    %% ══════════════════════════════════════════════
    %% ORM Models (Infrastructure — Lucid BaseModel)
    %% ══════════════════════════════════════════════

    class ReviewSession {
        +UUID id PK
        +UUID task_assignment_id FK
        +UUID reviewee_id FK
        +String status : pending | in_progress | completed | disputed
        +Boolean manager_review_completed
        +Integer peer_reviews_count
        +Integer required_peer_reviews
        +JSONB confirmations
        +DateTime deadline
        +DateTime completed_at
        +DateTime created_at
        +DateTime updated_at
    }

    class SkillReview {
        +UUID id PK
        +UUID review_session_id FK
        +UUID reviewer_id FK
        +String reviewer_type : manager | peer
        +UUID skill_id FK
        +String assigned_level_code : beginner ~ master
        +Text comment
        +DateTime created_at
        +DateTime updated_at
        --
        +$countCompletedByReviewer(userId, trx?)⚡
        +$countConfirmedByReviewer(userId, trx?)⚡
        +$countDisputedByReviewer(userId, trx?)⚡
        +$calculateSkillAvgPercentage(userId, skillId, trx?)⚡
    }

    class ReverseReview {
        +UUID id PK
        +UUID review_session_id FK
        +UUID reviewer_id FK
        +String target_type : peer | manager | project | organization
        +UUID target_id FK
        +Smallint rating : 1 ~ 5
        +Text comment
        +Boolean is_anonymous
        +DateTime created_at
    }

    class FlaggedReview {
        +UUID id PK
        +UUID skill_review_id FK
        +String flag_type : sudden_spike | mutual_high | bulk_same_level | frequency_anomaly | new_account_high | ip_collusion
        +String severity : low | medium | high | critical
        +String status : pending | reviewed | dismissed | confirmed
        +DateTime detected_at
        +UUID reviewed_by FK
        +DateTime reviewed_at
        +Text notes
        +DateTime created_at
        +DateTime updated_at
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Domain Entities (app/domain/reviews/entities/)
    %% Pure TypeScript, NO framework dependencies
    %% ══════════════════════════════════════════════

    class ReviewSessionEntity {
        <<Domain Entity>>
        +String id
        +String taskAssignmentId
        +String revieweeId
        +ReviewSessionStatus status
        +Boolean managerReviewCompleted
        +Number peerReviewsCount
        +Number requiredPeerReviews
        +ReviewConfirmationEntry[] confirmations
        +Date deadline
        +Date completedAt
        +Date createdAt
        +Date updatedAt
        --
        +get isCompleted() Boolean
        +get isPending() Boolean
        +get isOverdue() Boolean
        +get canAddPeerReview() Boolean
        +get peerReviewProgress() String
    }

    class SkillReviewEntity {
        <<Domain Entity>>
        +String id
        +String reviewSessionId
        +String reviewerId
        +SkillReviewerType reviewerType
        +String skillId
        +String assignedLevelCode
        +String comment
        +Date createdAt
        +Date updatedAt
        --
        +get isManagerReview() Boolean
        +get isPeerReview() Boolean
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Domain Mapper (app/domain/reviews/mapper/)
    %% Pure TypeScript — props ↔ Domain Entity
    %% ══════════════════════════════════════════════

    class ReviewDomainMapper {
        <<Domain Mapper>>
        +$toSessionEntity(props) ReviewSessionEntity
        +$toSessionProps(entity) ReviewSessionEntityProps
        +$toSkillReviewEntity(props) SkillReviewEntity
        +$toSkillReviewProps(entity) SkillReviewEntityProps
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Repository Interface (app/domain/reviews/repositories/)
    %% Contract — implemented by infra layer
    %% ══════════════════════════════════════════════

    class IReviewRepository {
        <<interface>>
        +findSessionById(id) Promise~ReviewSessionEntity|null~
        +findSessionsByReviewee(revieweeId) Promise~ReviewSessionEntity[]~
        +findSkillReviewsBySession(sessionId) Promise~SkillReviewEntity[]~
        +findPendingSessions() Promise~ReviewSessionEntity[]~
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Infrastructure Mapper (app/infra/reviews/mapper/)
    %% ORM Model ↔ Domain Entity
    %% ══════════════════════════════════════════════

    class ReviewInfraMapper {
        <<Infra Mapper>>
        +$toSessionDomain(model: ReviewSession) ReviewSessionEntity
        +$toSessionOrm(entity: Partial) Record
        +$toSkillReviewDomain(model: SkillReview) SkillReviewEntity
        +$toSkillReviewOrm(entity: Partial) Record
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Repository Implementation (app/infra/reviews/repositories/)
    %% Implements interface using Lucid ORM
    %% ══════════════════════════════════════════════

    class ReviewRepositoryImpl {
        <<Infra Repository>>
        +findSessionById(id) Promise~ReviewSessionEntity|null~
        +findSessionsByReviewee(revieweeId) Promise~ReviewSessionEntity[]~
        +findSkillReviewsBySession(sessionId) Promise~SkillReviewEntity[]~
        +findPendingSessions() Promise~ReviewSessionEntity[]~
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Application Mapper (app/actions/reviews/mapper/)
    %% Domain Entity → Response DTO
    %% ══════════════════════════════════════════════

    class ReviewApplicationMapper {
        <<Application Mapper>>
        +$toSessionResponse(entity) ReviewSessionResponseDTO
        +$toSkillReviewResponse(entity) SkillReviewResponseDTO
        +$toSummaryResponse(session, skillReviews) ReviewSummaryResponseDTO
    }

    %% ══════════════════════════════════════════════
    %% 🏛️ Response DTOs (app/actions/reviews/dtos/response/)
    %% ══════════════════════════════════════════════

    class ReviewSessionResponseDTO {
        <<Response DTO>>
        +String id
        +String taskAssignmentId
        +String revieweeId
        +String status
        +Boolean managerReviewCompleted
        +Number peerReviewsCount
        +Number requiredPeerReviews
        +String peerReviewProgress
        +String deadline
        +String createdAt
    }
    class SkillReviewResponseDTO {
        <<Response DTO>>
        +String id
        +String reviewSessionId
        +String reviewerId
        +String reviewerType
        +String skillId
        +String assignedLevelCode
        +String comment
    }
    class ReviewSummaryResponseDTO {
        <<Response DTO>>
        +ReviewSessionResponseDTO session
        +SkillReviewResponseDTO[] skillReviews
        +Number totalSkillReviews
    }

    %% ══════════════════════════════════════════════
    %% ORM Model Relationships (existing)
    %% ══════════════════════════════════════════════

    %% Review relationships
    ReviewSession "1" --> "*" SkillReview : contains
    ReviewSession "1" --> "*" ReverseReview : has reverse
    SkillReview "1" --> "0..1" FlaggedReview : may be flagged

    %% Review cross-references
    ReviewSession ..> TaskAssignment : triggered by (task_assignment_id)

    %% ══════════════════════════════════════════════
    %% 🏛️ Clean Architecture Relationships
    %% ══════════════════════════════════════════════

    %% Domain Mapper ↔ Domain Entity
    ReviewDomainMapper ..> ReviewSessionEntity : creates / exports
    ReviewDomainMapper ..> SkillReviewEntity : creates / exports

    %% Repository Interface ← Implementation (implements)
    IReviewRepository <|.. ReviewRepositoryImpl

    %% Infra Mapper: ORM Model → Domain Entity
    ReviewInfraMapper ..> ReviewSession : reads ORM
    ReviewInfraMapper ..> SkillReview : reads ORM
    ReviewInfraMapper ..> ReviewSessionEntity : produces
    ReviewInfraMapper ..> SkillReviewEntity : produces

    %% Repository Impl uses Infra Mapper
    ReviewRepositoryImpl ..> ReviewInfraMapper : uses

    %% Application Mapper: Domain Entity ↔ Response DTO
    ReviewApplicationMapper ..> ReviewSessionEntity : reads
    ReviewApplicationMapper ..> SkillReviewEntity : reads
    ReviewApplicationMapper ..> ReviewSessionResponseDTO : produces
    ReviewApplicationMapper ..> SkillReviewResponseDTO : produces
    ReviewApplicationMapper ..> ReviewSummaryResponseDTO : produces

    note for ReviewSession "Zero methods — fully driven by Commands.
    Reviews are PARALLEL (manager + peers independently).
    deadline = auto-set to NOW()+14 days on creation."
    note for ReverseReview "Only created_at — NO updated_at.
    Polymorphic target via target_type + target_id.
    Updates credibility_data of reviewer."
    note for FlaggedReview "'reviewed' status exists in CHECK but
    NEVER SET by any code (dead status).
    Only 3/6 flag_type patterns implemented."
    note for ReviewSessionEntity "🏛️ Pure domain entity (app/domain/reviews/entities/).
    Business logic: isOverdue, canAddPeerReview, peerReviewProgress.
    Framework-independent — NO AdonisJS imports."
    note for IReviewRepository "🏛️ Domain contract (app/domain/reviews/repositories/).
    Implemented by ReviewRepositoryImpl in infra layer."

