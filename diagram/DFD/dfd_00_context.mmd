    classDef db       fill:#D1FAE5,stroke:#059669,color:#064e3b,stroke-width:2px

    class U,FL,ADM entity
    class SUAR system
    class OAuth service
    class PG,MG,RD db

    style ext   fill:#EFF6FF,stroke:#BFDBFE,stroke-width:1.5px,color:#1e40af
