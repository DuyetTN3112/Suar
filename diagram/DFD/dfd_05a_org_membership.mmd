%% DFD 05A — Organization Membership
%% Scope: Create org, invite member, join request.

flowchart TD
    User([User])
    Admin([Org Owner / Org Admin])

    P1[["Create Organization"]]
    P2[["Invite Member"]]
    P3[["Join Request"]]
    P4[["Approve / Reject Join Request"]]

    D1[(users)]
    D2[(organizations)]
    D3[(organization_users)]
    D4[(organization_invitations
    or equivalent access storage)]
    D5[(audit_logs)]

    User --> P1
    Admin --> P2
    User --> P3
    Admin --> P4

    P1 --> D1
    P1 --> D2
    P1 --> D3
    P1 --> D5
    P2 --> D3
    P2 --> D4
    P2 --> D5
    P3 --> D3
    P3 --> D5
    P4 --> D3
    P4 --> D5

    classDef entity fill:#E3F2FD,stroke:#1565C0,color:#333,stroke-width:2px
    classDef process fill:#FFF9C4,stroke:#F57F17,color:#333,stroke-width:2px
    classDef datastore fill:#E8F5E9,stroke:#2E7D32,color:#333,stroke-width:2px
    class User,Admin entity
    class P1,P2,P3,P4 process
    class D1,D2,D3,D4,D5 datastore
