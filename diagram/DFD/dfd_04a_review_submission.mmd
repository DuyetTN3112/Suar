%% DFD 04A — Review Submission
%% Scope: Review session creation plus manager/peer submission only.

flowchart TD
    TaskDone([Task completed])
    Manager([Manager / PM])
    Peer([Peer reviewer])

    P1[["4A.1 Create review session"]]
    P2[["4A.2 Submit manager review"]]
    P3[["4A.3 Submit peer review"]]

    D1[(review_sessions)]
    D2[(skill_reviews)]
    D3[(tasks / assignments)]

    TaskDone --> P1
    P1 --> D3
    P1 --> D1

    Manager --> P2
    P2 --> D1
    P2 --> D2

    Peer --> P3
    P3 --> D1
    P3 --> D2

    classDef entity fill:#E3F2FD,stroke:#1565C0,color:#333,stroke-width:2px
    classDef process fill:#FFF9C4,stroke:#F57F17,color:#333,stroke-width:2px
    classDef datastore fill:#E8F5E9,stroke:#2E7D32,color:#333,stroke-width:2px
    class TaskDone,Manager,Peer entity
    class P1,P2,P3 process
    class D1,D2,D3 datastore

