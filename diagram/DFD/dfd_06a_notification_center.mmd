%% DFD 06A - Notification Center
%% Scope: List latest notifications, read-state updates, and cleanup.

flowchart TD
    User([Authenticated User])

    P1[["List notifications"]]
    P2[["Get latest notifications"]]
    P3[["Mark as read"]]
    P4[["Delete read notifications"]]

    D1[(notifications collection)]
    D2[(session / identity context)]

    User --> P1
    User --> P2
    User --> P3
    User --> P4

    P1 --> D1
    P1 --> D2
    P2 --> D1
    P3 --> D1
    P4 --> D1

    classDef entity fill:#E3F2FD,stroke:#1565C0,color:#333,stroke-width:2px
    classDef process fill:#FFF9C4,stroke:#F57F17,color:#333,stroke-width:2px
    classDef datastore fill:#E8F5E9,stroke:#2E7D32,color:#333,stroke-width:2px
    class User entity
    class P1,P2,P3,P4 process
    class D1,D2 datastore
