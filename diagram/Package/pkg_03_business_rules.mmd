%% pkg_03_business_rules: Business Rules Packages
%% Updated 2026-04-29.
%% Scope: pure domain rules, formulas, and policy results.

graph TD
    subgraph policies["app/domain/policies/"]
        POLICY_RESULT["policy_result.ts\nPolicyResult allow/deny"]
    end

    subgraph authz["app/domain/authorization/"]
        SYS_ACCESS["system_user_access_policy.ts"]
    end

    subgraph tasks["app/domain/tasks/"]
        TASK_STATE["task_state_machine.ts"]
        TASK_ASSIGN["task_assignment_rules.ts"]
        TASK_PERMISSION["task_permission_policy.ts"]
        TASK_STATUS["task_status_rules.ts"]
        TASK_TYPES["task_types.ts"]
    end

    subgraph projects["app/domain/projects/"]
        PROJECT_PERMISSION["project_permission_policy.ts"]
        PROJECT_STATE["project_state_rules.ts"]
        PROJECT_TYPES["project_types.ts"]
    end

    subgraph organizations["app/domain/organizations/"]
        ORG_PERMISSION["org_permission_policy.ts"]
        ORG_ACCESS["org_access_rules.ts"]
        ORG_RULES["organization_rules.ts"]
        ORG_TYPES["org_types.ts"]
    end

    subgraph reviews["app/domain/reviews/"]
        REVIEW_POLICY["review_policy.ts"]
        REVIEW_FORMULAS["review_formulas.ts\nincludes getLevelCodeFromPercentage"]
        REVIEW_TYPES["review_types.ts"]
    end

    subgraph users["app/domain/users/"]
        USER_MANAGEMENT["user_management_rules.ts"]
        SUBSCRIPTION["subscription_rules.ts"]
        PROFILE_METRICS["profile_metrics_rules.ts"]
        PROFILE_AGGREGATE["profile_aggregate_rules.ts"]
        PROFILE_SNAPSHOT["profile_snapshot_rules.ts"]
        USER_TYPES["user_types.ts"]
    end

    subgraph audit["app/domain/audit/"]
        CHANGE_FORMATTER["audit_change_formatter.ts"]
    end

    subgraph identifiers["app/domain/identifiers/"]
        ID_UTILS["id_utils.ts"]
    end

    SYS_ACCESS --> POLICY_RESULT
    TASK_STATE --> POLICY_RESULT
    TASK_ASSIGN --> POLICY_RESULT
    TASK_PERMISSION --> POLICY_RESULT
    TASK_STATUS --> POLICY_RESULT
    PROJECT_PERMISSION --> POLICY_RESULT
    PROJECT_STATE --> POLICY_RESULT
    ORG_PERMISSION --> POLICY_RESULT
    ORG_ACCESS --> POLICY_RESULT
    ORG_RULES --> POLICY_RESULT
    REVIEW_POLICY --> POLICY_RESULT
    USER_MANAGEMENT --> POLICY_RESULT
    PROFILE_SNAPSHOT --> POLICY_RESULT

    TASK_PERMISSION --> ID_UTILS
    PROJECT_PERMISSION --> ID_UTILS
    ORG_ACCESS --> ID_UTILS

    classDef policy fill:#FFF9C4,stroke:#F57F17,stroke-width:2px,color:#333
    classDef rule fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#333
    classDef util fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#333
    class POLICY_RESULT policy
    class SYS_ACCESS,TASK_STATE,TASK_ASSIGN,TASK_PERMISSION,TASK_STATUS,TASK_TYPES,PROJECT_PERMISSION,PROJECT_STATE,PROJECT_TYPES,ORG_PERMISSION,ORG_ACCESS,ORG_RULES,ORG_TYPES,REVIEW_POLICY,REVIEW_FORMULAS,REVIEW_TYPES,USER_MANAGEMENT,SUBSCRIPTION,PROFILE_METRICS,PROFILE_AGGREGATE,PROFILE_SNAPSHOT,USER_TYPES,CHANGE_FORMATTER rule
    class ID_UTILS util
