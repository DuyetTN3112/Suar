%% Package Diagram: Suar Platform — Application Layer & Business Rules (Detail)
%% Shows CQRS actions (Commands + Queries) and pure business rule modules.
%% Dependencies: calls Domain Layer (pkg_04) for models / validators / permissions.

graph TD
    subgraph application["📦 Application Layer (CQRS)"]
        direction TB
        subgraph task_actions["tasks/"]
            T_CMD["Commands\n(create, update,\nassign, delete)"]
            T_QRY["Queries\n(list, detail,\nboard, filter)"]
        end
        subgraph project_actions["projects/"]
            P_CMD["Commands\n(create, delete)\n⚠️ update/transfer\nhave no routes"]
            P_QRY["Queries\n(list, detail)"]
        end
        subgraph org_actions["organizations/"]
            O_CMD["Commands\n(create, invite,\njoin, roles)\n⚠️ update/delete\nroutes commented out"]
            O_QRY["Queries\n(list, detail,\nmembers)"]
        end
        subgraph conv_actions["conversations/"]
            C_CMD["Commands\n(create, send,\nrecall, add)"]
            C_QRY["Queries\n(list, messages)"]
        end
        subgraph review_actions["reviews/"]
            R_CMD["Commands\n(submit, respond)"]
            R_QRY["Queries\n(list, stats)"]
        end
        subgraph user_actions["users/"]
            U_CMD["Commands\n(approve, role,\ndeactivate, subscription)"]
            U_QRY["Queries\n(list, profile)"]
        end
    end

    subgraph rules["📦 Business Rules (Pure)"]
        direction LR
        subgraph shared_rules["shared/rules/"]
            POLICY_RESULT["PolicyResult\n(discriminated union)"]
            ENFORCE["enforcePolicy()\n(exception bridge)"]
        end
        subgraph task_rules["tasks/rules/"]
            TSM["TaskStateMachine"]
            TAR["TaskAssignmentRules"]
            TPP["TaskPermissionPolicy"]
        end
        subgraph project_rules["projects/rules/"]
            PPP["ProjectPermissionPolicy"]
            PSR["ProjectStateRules"]
        end
        subgraph org_rules["organizations/rules/"]
            OPP["OrgPermissionPolicy"]
        end
        subgraph review_rules_pkg["reviews/rules/"]
            RP["ReviewPolicy"]
            RF["ReviewFormulas"]
        end
        subgraph conv_rules["conversations/rules/"]
            CPP["ConversationPermPolicy"]
            CSR["ConversationStateRules"]
        end
        subgraph user_rules["users/rules/"]
            UMR["UserManagementRules"]
        end
    end

    T_CMD --> task_rules
    P_CMD --> project_rules
    O_CMD --> org_rules
    R_CMD --> review_rules_pkg
    C_CMD --> conv_rules
    U_CMD --> user_rules

    task_rules --> POLICY_RESULT
    project_rules --> POLICY_RESULT
    org_rules --> POLICY_RESULT
    review_rules_pkg --> POLICY_RESULT
    conv_rules --> POLICY_RESULT
    user_rules --> POLICY_RESULT

    classDef appStyle fill:#FFF9C4,stroke:#F57F17,stroke-width:2px,color:#E65100
    classDef ruleStyle fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#1B5E20
    class T_CMD,T_QRY,P_CMD,P_QRY,O_CMD,O_QRY,C_CMD,C_QRY,R_CMD,R_QRY,U_CMD,U_QRY appStyle
    class POLICY_RESULT,ENFORCE,TSM,TAR,TPP,PPP,PSR,OPP,RP,RF,CPP,CSR,UMR ruleStyle
