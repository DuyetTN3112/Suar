%% Package Diagram: Suar Platform - Application Layer & Business Rules
%% Updated 2026-05-12.
%% This file keeps the older pkg_03_application name but reflects the current action boundaries.

graph TD
    subgraph application["Application Layer - app/actions"]
        AUTHZ_API["authorization/public_api.ts\nenforcePolicy"]
        MODULE_APIS["module public APIs"]
        COMMANDS["Commands"]
        QUERIES["Queries"]
        DTOS["DTOs + mappers"]
        BASES["module-local base_command/base_query"]
    end

    subgraph domain["Domain Layer - app/domain"]
        POLICY_RESULT["PolicyResult"]
        RULES["pure rules and policies"]
        FORMULAS["review formulas"]
        TYPES["domain types and id utils"]
    end

    subgraph infra["Infrastructure Layer - app/infra"]
        REPOS["repository implementations"]
        MAPPERS["infra mappers"]
        CACHE_LOGGER["cache/logger adapters"]
    end

    subgraph drained["Drained boundaries"]
        SHARED["app/actions/shared\nno active TS files"]
        SERVICES["app/services\nno active TS files"]
    end

    MODULE_APIS --> COMMANDS
    MODULE_APIS --> QUERIES
    COMMANDS --> AUTHZ_API
    QUERIES --> AUTHZ_API
    AUTHZ_API --> POLICY_RESULT
    COMMANDS --> RULES
    COMMANDS --> FORMULAS
    COMMANDS --> REPOS
    QUERIES --> REPOS
    COMMANDS --> DTOS
    QUERIES --> DTOS
    COMMANDS --> BASES
    QUERIES --> BASES

    RULES --> POLICY_RESULT
    FORMULAS --> TYPES
    REPOS --> MAPPERS
    MODULE_APIS -.-> SHARED
    MODULE_APIS -.-> SERVICES

    classDef app fill:#FFF9C4,stroke:#F57F17,stroke-width:2px,color:#333
    classDef dom fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#333
    classDef infraStyle fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#333
    classDef drainedStyle fill:#ECEFF1,stroke:#546E7A,stroke-width:2px,color:#333,stroke-dasharray: 5 5
    class AUTHZ_API,MODULE_APIS,COMMANDS,QUERIES,DTOS,BASES app
    class POLICY_RESULT,RULES,FORMULAS,TYPES dom
    class REPOS,MAPPERS,CACHE_LOGGER infraStyle
    class SHARED,SERVICES drainedStyle
