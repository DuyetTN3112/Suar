%% Package Diagram: Suar Platform - High-Level Layer Overview
%% Updated 2026-05-12.

graph TD
    external["External Dependencies\nAdonisJS, Lucid, VineJS, Svelte, Inertia, Mongoose, Ally"]
    presentation["Presentation Layer\nroutes, controllers, middleware\nSvelte pages, stores, components"]
    application["Application Layer\nCQRS commands/queries\nmodule public APIs\nDTOs, mappers, module services"]
    domain["Domain Layer\nentities, formulas, policies\nstate rules, repository interfaces"]
    infra["Infrastructure Layer\napp/infra repositories\nLucid/Mongo/cache/logger adapters\nrepository providers + barrels"]
    data["Data Layer\nPostgreSQL, MongoDB, Redis"]
    crosscutting["Cross-Cutting Runtime\nevents, listeners, cache invalidation\nrealtime configured but inactive"]
    drained["Drained legacy boundaries\napp/actions/shared + app/services\nno active TS files"]

    presentation --> application
    application --> domain
    application --> infra
    infra --> data
    application --> crosscutting
    crosscutting --> application
    crosscutting --> infra
    presentation --> external
    infra --> external
    application -.-> drained

    classDef layerStyle fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#0D47A1
    classDef drainedStyle fill:#ECEFF1,stroke:#546E7A,stroke-width:2px,color:#263238,stroke-dasharray: 5 5
    class external,presentation,application,domain,infra,data,crosscutting layerStyle
    class drained drainedStyle
