%% ─────────────────────────────────────────────────────────────
%% pkg_02_application_layer: CQRS Application Layer — Actions
%% ─────────────────────────────────────────────────────────────
%% Scope: All action sub-packages (Commands + Queries) by domain.
%% Related: pkg_01_overview.mmd — overall architecture context
%% ✅ Updated 2026-03: Note legacy repos still in use
%% ─────────────────────────────────────────────────────────────

graph TD
    subgraph application["Application Layer (CQRS) — app/actions/"]
        direction LR

        subgraph task_actions["tasks/"]
            T_CMD["Commands
            (CreateTask, UpdateTask,
            DeleteTask, AssignTask,
            UpdateStatus, UpdateSortOrder,
            BatchUpdateStatus,
            CreateTaskStatus, UpdateWorkflow,
            SeedDefaultStatuses)"]
            T_QRY["Queries
            (ListTasks, GetTask,
            GetTaskBoard, GetTaskStats,
            ListTaskStatuses, ListWorkflow)"]
            T_MAP["Mapper
            (tasks/mapper/)
            Request DTO → Entity
            Entity → Response DTO"]
        end

        subgraph project_actions["projects/"]
            P_CMD["Commands
            (CreateProject, DeleteProject,
            AddMember, RemoveMember,
            TransferOwnership)"]
            P_QRY["Queries
            (ListProjects, GetProjectDetail,
            GetProjectMembers)"]
            P_MAP["Mapper
            (projects/mapper/)"]
        end

        subgraph org_actions["organizations/"]
            O_CMD["Commands
            (CreateOrg, InviteUser,
            AddMember, RemoveMember,
            UpdateMemberRole, CreateJoinRequest,
            ProcessJoinRequest,
            TransferOwnership, UpdateOrg,
            DeleteOrg, SwitchOrg)"]
            O_QRY["Queries
            (ListOrgs, GetOrg,
            GetOrgMembers)"]
            O_MAP["Mapper
            (organizations/mapper/)"]
        end

        subgraph conv_actions["conversations/"]
            C_CMD["Commands
            (CreateConversation,
            SendMessage, RecallMessage,
            AddParticipant)"]
            C_QRY["Queries
            (ListConversations,
            GetMessages)"]
            C_MAP["Mapper
            (conversations/mapper/)"]
        end

        subgraph review_actions["reviews/"]
            R_CMD["Commands
            (SubmitSkillReview,
            SubmitReverseReview,
            ConfirmReview,
            ResolveFlaggedReview,
            CalculateTrustScore,
            CalculateSpiderChart,
            DetectAnomaly,
            UpdateReviewerCredibility)"]
            R_QRY["Queries
            (GetReviewSession,
            GetUserReviews,
            GetPendingReviews,
            GetFlaggedReviews)"]
            R_MAP["Mapper
            (reviews/mapper/)"]
        end

        subgraph user_actions["users/"]
            U_CMD["Commands
            (ApproveUser, UpdateRole,
            DeactivateUser,
            AddUserSkill, RemoveUserSkill)"]
            U_QRY["Queries
            (ListUsers, GetUserProfile,
            GetActiveSkills)"]
            U_MAP["Mapper
            (users/mapper/)"]
        end

        subgraph auth_actions["auth/"]
            A_CMD["Commands
            (SocialLogin)"]
        end

        subgraph common_actions["common/"]
            CMN["CreateNotification
            CreateAuditLog
            AuditLogging"]
        end

        subgraph shared_actions["shared/"]
            SHR["BaseCommand / BaseQuery
            GetActiveSkillsQuery"]
        end

        subgraph dtos_pkg["dtos/"]
            REQ_DTOS["Request DTOs
            (dtos/request/)
            Type-safe input"]
            RES_DTOS["Response DTOs
            (dtos/response/)
            Type-safe output"]
        end
    end

    subgraph rules["Business Rules"]
        TASK_RULES["tasks/rules/
        (TaskStateMachine,
        TaskPermissionPolicy,
        TaskStatusRules,
        TaskAssignmentRules)"]
        ORG_RULES["org/rules/
        (OrgPermissionPolicy)"]
        PROJ_RULES["projects/rules/
        (ProjectPermissionPolicy)"]
        REVIEW_RULES["reviews/rules/
        (ReviewPolicy, ReviewFormulas)"]
        CONV_RULES["conversations/rules/"]
        USER_RULES["users/rules/"]
    end

    subgraph repos["Repositories ⚠️ Currently Using Legacy"]
        TS_REPO["TaskStatusRepository ⚠️"]
        TW_REPO["TaskWorkflowTransitionRepository ⚠️"]
        TASK_REPO["TaskRepository ⚠️"]
        PROJ_REPO["ProjectRepository ⚠️"]
        ORG_REPO["OrganizationRepository ⚠️"]
        USER_REPO["UserRepository ⚠️"]
        SKILL_REPO["SkillRepository ⚠️"]
        AUDIT_REPO["LucidAuditLogRepository ⚠️"]
        NOTE_REPO["⚠️ All 22 legacy repos still active\n(174 imports across 95 files)\nInfra repos created but unused\nMigration TODO"]
    end

    T_CMD --> TASK_RULES
    T_CMD --> TS_REPO
    T_CMD --> TW_REPO
    T_CMD --> TASK_REPO
    T_CMD --> T_MAP
    P_CMD --> PROJ_RULES
    P_CMD --> PROJ_REPO
    P_CMD --> P_MAP
    O_CMD --> ORG_RULES
    O_CMD --> ORG_REPO
    O_CMD --> O_MAP
    R_CMD --> REVIEW_RULES
    R_CMD --> SKILL_REPO
    R_CMD --> R_MAP
    C_CMD --> CONV_RULES
    C_CMD --> C_MAP
    U_CMD --> USER_RULES
    U_CMD --> SKILL_REPO
    U_CMD --> U_MAP
    T_QRY --> TS_REPO
    T_QRY --> TW_REPO
    T_QRY --> T_MAP
    U_QRY --> SKILL_REPO
    U_QRY --> U_MAP
    common_actions --> AUDIT_REPO

