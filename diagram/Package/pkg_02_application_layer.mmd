    classDef repoStyle fill:#FCE4EC,stroke:#C62828,stroke-width:2px
    classDef mapStyle fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px
    classDef dtoStyle fill:#E0F7FA,stroke:#00695C,stroke-width:2px

    class T_CMD,P_CMD,O_CMD,C_CMD,R_CMD,U_CMD,A_CMD cmdStyle
    class T_QRY,P_QRY,O_QRY,C_QRY,R_QRY,U_QRY qryStyle
    class TASK_RULES,ORG_RULES,PROJ_RULES,REVIEW_RULES,CONV_RULES,USER_RULES ruleStyle
    class TS_REPO,TW_REPO,TASK_REPO,PROJ_REPO,ORG_REPO,USER_REPO,SKILL_REPO,AUDIT_REPO repoStyle
    class T_MAP,P_MAP,O_MAP,C_MAP,R_MAP,U_MAP mapStyle
    class REQ_DTOS,RES_DTOS dtoStyle
