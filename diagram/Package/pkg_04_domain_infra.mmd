%% Package Diagram: Suar Platform - Domain & Infrastructure Layers
%% Updated 2026-05-12.
%% Domain remains framework-free; infra owns persistence access.

graph TD
    subgraph app_boundary["Application Boundary"]
        PUBLIC_API["Module public APIs\napp/actions/*/public_api.ts"]
        ACTIONS["Commands + Queries\nexplicit cross-module imports"]
    end

    subgraph domain["Domain Layer"]
        ENTITIES["Entities + value props"]
        FORMULAS["Formulas\nreview_formulas.ts"]
        POLICIES["Policies + state rules\nPolicyResult pattern"]
        REPO_IFACE["Repository interfaces"]
        DOMAIN_MAPPER["Domain mappers"]
    end

    subgraph infra["Infrastructure Layer"]
        REPO_IMPL["Repository implementations\napp/infra/*/repositories"]
        INFRA_MAPPER["Infra mappers"]
        CACHE_LOGGER["Cache + logger adapters\napp/infra/cache, app/infra/logger"]
        REPO_PROVIDERS["Repository providers + barrels\nMongo providers, Lucid read/write repositories"]
    end

    subgraph models["Model Layer"]
        LUCID_MODELS["Lucid models\nPostgreSQL tables"]
        MONGO_MODELS["Mongo models\naudit, notification, activity"]
    end

    subgraph data["Data Layer"]
        PG[("PostgreSQL")]
        MONGO[("MongoDB")]
        REDIS[("Redis")]
    end

    subgraph drained["Drained Legacy Boundaries"]
        SERVICES["app/services\nno active TS files"]
        SHARED["app/actions/shared\nno active TS files"]
    end

    PUBLIC_API --> ACTIONS
    ACTIONS --> ENTITIES
    ACTIONS --> FORMULAS
    ACTIONS --> POLICIES
    ACTIONS --> REPO_IFACE
    ACTIONS --> REPO_IMPL

    ENTITIES --> DOMAIN_MAPPER
    REPO_IFACE --> REPO_IMPL
    REPO_IMPL --> INFRA_MAPPER
    REPO_IMPL --> LUCID_MODELS
    REPO_PROVIDERS --> MONGO_MODELS
    CACHE_LOGGER --> REDIS

    LUCID_MODELS --> PG
    MONGO_MODELS --> MONGO

    PUBLIC_API -.-> SERVICES
    PUBLIC_API -.-> SHARED

    classDef appStyle fill:#FFF9C4,stroke:#F57F17,stroke-width:2px,color:#333
    classDef domStyle fill:#FCE4EC,stroke:#C62828,stroke-width:2px,color:#333
    classDef infraStyle fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#333
    classDef modelStyle fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#333
    classDef dataStyle fill:#F3E5F5,stroke:#6A1B9A,stroke-width:2px,color:#333
    classDef drainedStyle fill:#ECEFF1,stroke:#546E7A,stroke-width:2px,color:#333,stroke-dasharray: 5 5
    class PUBLIC_API,ACTIONS appStyle
    class ENTITIES,FORMULAS,POLICIES,REPO_IFACE,DOMAIN_MAPPER domStyle
    class REPO_IMPL,INFRA_MAPPER,CACHE_LOGGER,REPO_PROVIDERS infraStyle
    class LUCID_MODELS,MONGO_MODELS modelStyle
    class PG,MONGO,REDIS dataStyle
    class SERVICES,SHARED drainedStyle
