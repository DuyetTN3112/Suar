%% ─────────────────────────────────────────────────────────────────────────────
%% pkg_01_system_packages: Suar Platform — Full System Package Map (COMBINED)
%% ─────────────────────────────────────────────────────────────────────────────
%% NOTE: This is the combined reference diagram for all package layers.
%% For easier reading, this diagram has been split into focused sub-diagrams:
%%   pkg_01_overview.mmd          -- High-level 5-layer overview (start here)
%%   pkg_02_application_layer.mmd -- CQRS Actions breakdown by domain
%%   pkg_03_business_rules.mmd    -- Business rules (pure, zero DB deps)
%%   pkg_04_domain_infra.mmd      -- Domain models, repos, DB backends
%%   pkg_05_crosscutting.mmd      -- Events, Listeners, Constants, Libs
%% ─────────────────────────────────────────────────────────────────────────────
%% Greenwich Thesis -- shows module dependencies and package structure
%% Based on AdonisJS 6 + CQRS architecture
%% Cross-referenced with actual backend code 2024
%% Fixed: Route count 10->12, Controller count 107->110
%% Fixed: Middleware names (no Permission/SilentAuth)
%% Fixed: Firebase is for phone auth only (NOT push notifications)
%% Removed: NotificationService, AuditService (don't exist as classes)
%% Fixed: Repositories cover all domain entities (not only audit/notification)

graph TD
    %% ==============================
    %% External Packages
    %% ==============================
    subgraph external["📦 External Dependencies"]
        direction LR
        ADONIS["AdonisJS 6
        (HTTP, Auth, Session,
        Shield, Limiter)"]
        LUCID["Lucid ORM
        (PostgreSQL driver)"]
        VINE["VineJS
        (Validation)"]
        INERTIA["Inertia.js
        (SSR Adapter)"]
        SVELTE["Svelte 5
        (Frontend Framework)"]
        TRANSMIT["@adonisjs/transmit
        (WebSocket / SSE)"]
        MONGOOSE["Mongoose
        (MongoDB ODM)"]
        ALLY["@adonisjs/ally
        (OAuth: Google, GitHub)"]
        FIREBASE["Firebase Client SDK
        (Phone Auth — planned)"]
    end

    %% ==============================
    %% Presentation Package
    %% ==============================
    subgraph presentation["📦 Presentation Layer"]
        direction TB
        subgraph routes_pkg["start/routes/"]
            ROUTES["Routes
            (12 route files)"]
        end
        subgraph controllers_pkg["app/controllers/"]
            CONTROLLERS["110 Controllers
            (thin, zero Model import)"]
        end
        subgraph middleware_pkg["app/middleware/"]
            MIDDLEWARE["Auth · Guest
            AuthorizeRole ·
            RequireOrganization ·
            Throttle · AuditLog"]
        end
        subgraph frontend_pkg["inertia/"]
            PAGES["Pages
            (Svelte components)"]
            STORES["Stores
            (Svelte stores)"]
            HOOKS["Hooks
            (Composables)"]
            COMPONENTS["UI Components
            (Shadcn-Svelte)"]
        end
    end

    %% ==============================
    %% Application Package (CQRS)
    %% ==============================
    subgraph application["📦 Application Layer (CQRS)"]
        direction TB
        subgraph actions_pkg["app/actions/"]
            direction LR
            subgraph task_actions["tasks/"]
                T_CMD["Commands
                (create, update,
                assign, delete)"]
                T_QRY["Queries
                (list, detail,
                board, filter)"]
            end
            subgraph project_actions["projects/"]
                P_CMD["Commands
                (create, delete)
                ⚠️ update/transfer
                have no routes"]
                P_QRY["Queries
                (list, detail)"]
            end
            subgraph org_actions["organizations/"]
                O_CMD["Commands
                (create, invite,
                join, roles)
                ⚠️ update/delete
                routes commented out"]
                O_QRY["Queries
                (list, detail,
                members)"]
            end
            subgraph conv_actions["conversations/"]
                C_CMD["Commands
                (create, send,
                recall, add)"]
                C_QRY["Queries
                (list, messages)"]
            end
            subgraph review_actions["reviews/"]
                R_CMD["Commands
                (submit, respond)"]
                R_QRY["Queries
                (list, stats)"]
            end
            subgraph user_actions["users/"]
                U_CMD["Commands
                (approve, role,
                deactivate, subscription)"]
                U_QRY["Queries
                (list, profile)"]
            end
        end
    end

    %% ==============================
    %% Rules Package (Pure Business Logic)
    %% ==============================
    subgraph rules["📦 Business Rules (Pure)"]
        direction LR
        subgraph shared_rules["shared/rules/"]
            POLICY_RESULT["PolicyResult
            (discriminated union)"]
            ENFORCE["enforcePolicy()
            (exception bridge)"]
        end
        subgraph task_rules["tasks/rules/"]
            TSM["TaskStateMachine"]
            TAR["TaskAssignmentRules"]
            TPP["TaskPermissionPolicy"]
        end
        subgraph project_rules["projects/rules/"]
            PPP["ProjectPermissionPolicy"]
            PSR["ProjectStateRules"]
        end
        subgraph org_rules["organizations/rules/"]
            OPP["OrgPermissionPolicy"]
        end
        subgraph review_rules_pkg["reviews/rules/"]
            RP["ReviewPolicy"]
            RF["ReviewFormulas"]
        end
        subgraph conv_rules["conversations/rules/"]
            CPP["ConversationPermPolicy"]
            CSR["ConversationStateRules"]
        end
        subgraph user_rules["users/rules/"]
            UMR["UserManagementRules"]
        end
    end

    %% ==============================
    %% Domain Package
    %% ==============================
    subgraph domain["📦 Domain Layer"]
        direction LR
        subgraph models_pkg["app/models/"]
            MODELS["27 Lucid + 3 Mongoose
            Models
            (Pure entities:
            columns, relationships,
            hooks only)"]
        end
        subgraph services_pkg["app/services/"]
            PERM_SVC["PermissionService
            (17 methods, cached)
            3-tier: System→Org→Project"]
        end
        subgraph validators_pkg["app/validators/"]
            VALIDATORS["VineJS Validators
            (type-safe input)"]
        end
        subgraph repos_pkg["app/repositories/"]
            REPOS["Repositories
            (TaskStatusRepository,
            TaskWorkflowTransitionRepository,
            TaskRepository, ProjectRepository,
            OrgRepository, UserRepository,
            SkillRepository + RepositoryFactory
            for multi-DB audit + notification)"]
        end
    end

    %% ==============================
    %% Infrastructure Package
    %% ==============================
    subgraph infrastructure["📦 Infrastructure Layer"]
        direction LR
        PG[("PostgreSQL
        27 tables
        UUIDv7")]
        MONGO[("MongoDB Atlas
        audit_logs
        notifications
        user_activity_logs")]
        REDIS[("Redis
        DB0: Sessions + Locks
        DB1: App Cache")]
    end

    %% ==============================
    %% Cross-Cutting Package
    %% ==============================
    subgraph crosscutting["📦 Cross-Cutting Concerns"]
        direction LR
        subgraph events_pkg["app/events/"]
            EVENTS["Event Definitions"]
        end
        subgraph listeners_pkg["app/listeners/"]
            LISTENERS["7 Listeners
            (Audit, Notification,
            Cache, Review,
            Cleanup, Activity,
            Trigger)"]
        end
        subgraph constants_pkg["app/constants/"]
            CONSTANTS["Enums & Constants
            (roles, statuses,
            permissions, limits)"]
        end
        subgraph libs_pkg["app/libs/"]
            LIBS["Utilities
            (id_utils, date_utils,
            string_utils)"]
        end
    end

    %% ==============================
    %% Package Dependencies
    %% ==============================

    %% Presentation → Application
    ROUTES --> CONTROLLERS
    CONTROLLERS --> MIDDLEWARE
    CONTROLLERS -->|"DTO"| actions_pkg

    %% Frontend → External
    PAGES --> SVELTE
    PAGES --> COMPONENTS
    COMPONENTS --> SVELTE
    STORES --> SVELTE
    CONTROLLERS -->|"Inertia render"| INERTIA
    INERTIA --> PAGES

    %% Application → Rules (pure)
    T_CMD --> task_rules
    P_CMD --> project_rules
    O_CMD --> org_rules
    R_CMD --> review_rules_pkg
    C_CMD --> conv_rules
    U_CMD --> user_rules

    %% Rules → Shared
    task_rules --> POLICY_RESULT
    project_rules --> POLICY_RESULT
    org_rules --> POLICY_RESULT
    review_rules_pkg --> POLICY_RESULT
    conv_rules --> POLICY_RESULT
    user_rules --> POLICY_RESULT

    %% Application → Domain
    actions_pkg -->|"validate"| VALIDATORS
    actions_pkg -->|"permissions"| PERM_SVC
    actions_pkg -->|"read/write"| MODELS
    actions_pkg -->|"repository"| REPOS

    %% Domain → Infrastructure
    MODELS --> LUCID --> PG
    REPOS --> MONGOOSE --> MONGO
    PERM_SVC --> REDIS
    CONTROLLERS --> ADONIS

    %% Cross-cutting connections
    actions_pkg -->|"emit events"| EVENTS
    EVENTS --> LISTENERS
    LISTENERS --> REPOS
    LISTENERS -.->|"⚠️ transport=null"| TRANSMIT
    actions_pkg --> CONSTANTS
    actions_pkg --> LIBS

    %% ==============================
    %% Styling
    %% ==============================
    classDef extStyle fill:#ECEFF1,stroke:#546E7A,stroke-width:2px,color:#263238
    classDef presStyle fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#0D47A1
    classDef appStyle fill:#FFF9C4,stroke:#F57F17,stroke-width:2px,color:#E65100
    classDef ruleStyle fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#1B5E20
    classDef domStyle fill:#FCE4EC,stroke:#C62828,stroke-width:2px,color:#B71C1C
    classDef infraStyle fill:#F3E5F5,stroke:#6A1B9A,stroke-width:2px,color:#4A148C
    classDef crossStyle fill:#FFF3E0,stroke:#E65100,stroke-width:2px,color:#BF360C

    class ADONIS,LUCID,VINE,INERTIA,SVELTE,TRANSMIT,MONGOOSE,ALLY,FIREBASE extStyle
    class ROUTES,CONTROLLERS,MIDDLEWARE,PAGES,STORES,HOOKS,COMPONENTS presStyle
    class T_CMD,T_QRY,P_CMD,P_QRY,O_CMD,O_QRY,C_CMD,C_QRY,R_CMD,R_QRY,U_CMD,U_QRY appStyle
    class POLICY_RESULT,ENFORCE,TSM,TAR,TPP,PPP,PSR,OPP,RP,RF,CPP,CSR,UMR ruleStyle
    class MODELS,PERM_SVC,VALIDATORS,REPOS domStyle
    class PG,MONGO,REDIS infraStyle
    class EVENTS,LISTENERS,CONSTANTS,LIBS crossStyle


