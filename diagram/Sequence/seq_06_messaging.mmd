%% seq_06_messaging.mmd
%% Scope: Implemented messaging-related runtime flow only.
%% Note:
%%   - End-user conversation/message routes are not wired in the current app.
%%   - This diagram documents the confirmed interaction that still touches
%%     legacy messaging tables: cleanup on organization-member removal.

sequenceDiagram
    autonumber
    actor Admin as Org Admin
    participant C as RemoveMemberController
    participant Cmd as RemoveMemberCommand
    participant Evt as Event Bus
    participant L as CleanupListener
    participant DB as PostgreSQL

    Admin->>C: Remove member from organization
    C->>Cmd: execute(dto)
    Cmd->>DB: Update organization membership
    Cmd->>Evt: emit(organization:user_removed)

    Evt->>L: Dispatch cleanup event
    L->>DB: Check if conversations tables exist

    alt Legacy messaging tables exist
        L->>DB: DELETE conversation_participants<br/>for removed user in org conversations
        L-->>Evt: Cleanup completed
    else Tables absent
        L-->>Evt: Skip messaging cleanup
    end
