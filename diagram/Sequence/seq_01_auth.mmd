
%% ─────────────────────────────────────────────────────────────
%% seq_01: OAuth Authentication (Google / GitHub)
%% ─────────────────────────────────────────────────────────────
%% NO email/password — OAuth only
%% Session-based (cookie), NOT JWT
%% Rate limit: 5 req/min/IP (loginThrottle)
%% SocialLoginCommand: 3-step cascade
%% ─────────────────────────────────────────────────────────────

sequenceDiagram
    autonumber
    actor U as User
    participant B as Browser (Svelte)
    participant S as AdonisJS Server
    participant CMD as SocialLoginCommand
    participant Entity as Domain Entity
    participant Repo as Repository
    participant DB as PostgreSQL
    participant OAuth as OAuth Provider<br/>(Google/GitHub)

    Note over U, OAuth: === OAUTH LOGIN / REGISTER ===

    U->>B: Click "Login with Google" or "Login with GitHub"
    B->>S: GET /auth/:provider/redirect
    Note right of S: loginThrottle: 5 req/min/IP
    S->>S: Validate provider ∈ {google, github}
    S-->>B: 302 Redirect → OAuth Provider
    B->>OAuth: Authorization request
    OAuth-->>U: Show consent page
    U->>OAuth: Accept consent
    OAuth-->>B: Redirect callback + code
    B->>S: GET /auth/:provider/callback?code=xxx

    alt OAuth error (denied/state mismatch)
        S-->>B: Redirect /login?error=message
        B-->>U: Show error on login page
    else OAuth success
        S->>OAuth: Exchange code for access token
        OAuth-->>S: Access token + refresh token
        S->>OAuth: GET /userinfo
        OAuth-->>S: { email, name, avatar, provider_id }

        alt No email in response
            S-->>B: Redirect /login?error=email required
            B-->>U: Show error
        else Email present
            S->>CMD: execute(provider, socialData)
            Note over CMD: App Mapper: Request DTO → Domain params

            Note over CMD, DB: Step 1: Lookup by (provider, provider_id)
            CMD->>Repo: findByProvider(provider, providerId)
            Repo->>DB: SELECT * FROM user_oauth_providers<br/>WHERE provider = ? AND provider_id = ?
            DB-->>Repo: Result
            Note over Repo: Infra Mapper: ORM Model → Domain Entity
            Repo-->>CMD: OAuthProvider entity or null

            alt Step 1: Provider found (returning user)
                CMD->>Entity: updateTokens(accessToken, refreshToken)
                CMD->>Repo: save(oauthProviderEntity)
                Repo->>DB: UPDATE user_oauth_providers<br/>SET access_token, refresh_token
                DB-->>Repo: Updated
                Repo-->>CMD: Updated entity
                CMD->>CMD: Emit user:login event
                CMD-->>S: { user, isNewUser: false, redirectTo: '/tasks' }

            else Step 2: Lookup by email
                CMD->>Repo: findUserByEmail(email)
                Repo->>DB: SELECT * FROM users WHERE email = ?
                DB-->>Repo: Result
                Note over Repo: Infra Mapper: ORM Model → Domain Entity
                Repo-->>CMD: User entity or null

                alt Step 2: Email found (link provider)
                    CMD->>Entity: OAuthProvider.create(userId,<br/>provider, providerId, tokens)
                    Note over Entity: Domain validation
                    CMD->>Repo: saveOAuthProvider(entity)
                    Note over Repo: Infra Mapper: Domain Entity → ORM Model
                    Repo->>DB: INSERT INTO user_oauth_providers<br/>(user_id, provider, provider_id, tokens)
                    DB-->>Repo: Provider linked
                    Repo-->>CMD: Persisted entity
                    CMD->>CMD: Emit user:login event
                    CMD-->>S: { user, isNewUser: false, redirectTo: '/tasks' }

                else Step 3: New user (first-time sign-up)
                    Note over CMD, DB: DB Transaction
                    CMD->>Entity: User.create(email, username,<br/>status='active',<br/>system_role='registered_user',<br/>auth_method=provider)
                    Note over Entity: Domain validation
                    CMD->>Repo: save(userEntity)
                    Note over Repo: Infra Mapper: Domain Entity → ORM Model
                    Repo->>DB: INSERT INTO users<br/>(email, username, status='active',<br/>system_role='registered_user',<br/>auth_method=provider)
                    DB-->>Repo: User created
                    Repo-->>CMD: User entity
                    CMD->>Entity: OAuthProvider.create(userId,<br/>provider, providerId, tokens)
                    CMD->>Repo: saveOAuthProvider(entity)
                    Repo->>DB: INSERT INTO user_oauth_providers<br/>(user_id, provider, provider_id, tokens)
                    DB-->>Repo: Provider saved
                    Repo-->>CMD: Provider entity
                    CMD->>CMD: Emit user:login event
                    CMD-->>S: { user, isNewUser: true, redirectTo: '/organizations' }
                end
            end

            S->>S: auth.use('web').login(user)<br/>→ Create server session (cookie)
            S-->>B: 302 Redirect → /tasks or /organizations
            B-->>U: Show dashboard
        end
    end

    Note over U, DB: === LOGOUT ===

    U->>B: Click "Logout"
    B->>S: POST /logout
    S->>S: LogoutUserCommand:<br/>auth.use('web').logout()<br/>session.forget('auth')<br/>clear Inertia shared data
    S->>S: Emit user:logout event
    S->>Repo: logAudit(event)
    Repo->>DB: Create audit_log entry
    S-->>B: Redirect /login + flash message
    B-->>U: Show login page

