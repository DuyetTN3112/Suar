
%% seq_01: OAuth Authentication (Google / GitHub)
%% Runtime source:
%%   - GET /auth/:provider/redirect
%%   - GET /auth/:provider/callback
%%   - app/actions/auth/commands/social_login_command.ts
%% Notes:
%%   - OAuth only, no email/password flow
%%   - Session-based auth via web guard
%%   - Redirect depends on system_role + current_organization_id

sequenceDiagram
    autonumber
    actor U as User
    participant B as Browser (Svelte)
    participant S as Auth Controller
    participant CMD as SocialLoginCommand
    participant OAuthRepo as OAuth Provider Repo
    participant UserRepo as User Repo
    participant DB as PostgreSQL
    participant OAuth as OAuth Provider<br/>(Google/GitHub)

    Note over U, OAuth: OAuth login and first-time sign-up share the same callback flow

    U->>B: Click "Login with Google" or "Login with GitHub"
    B->>S: GET /auth/:provider/redirect
    Note right of S: loginThrottle: 5 req/min/IP
    S->>S: Validate provider ∈ {google, github}
    S-->>B: 302 Redirect → OAuth Provider
    B->>OAuth: Authorization request
    OAuth-->>U: Show consent page
    U->>OAuth: Accept consent
    OAuth-->>B: Redirect callback + code
    B->>S: GET /auth/:provider/callback?code=xxx

    alt OAuth error (denied/state mismatch)
        S-->>B: Redirect /login?error=message
        B-->>U: Show error on login page
    else OAuth success
        S->>OAuth: Exchange code for access token
        OAuth-->>S: Access token + refresh token
        S->>OAuth: GET /userinfo
        OAuth-->>S: { email, name, avatar, provider_id }

        alt No email in response
            S-->>B: Redirect /login?error=email required
            B-->>U: Show error
        else Email present
            S->>CMD: execute(provider, socialData)

            Note over CMD, DB: Step 1: returning user by OAuth provider id
            CMD->>OAuthRepo: findByProviderAndProviderId(provider, providerId)
            OAuthRepo->>DB: SELECT user_oauth_providers
            DB-->>OAuthRepo: OAuth record or null
            OAuthRepo-->>CMD: OAuth record or null

            alt Step 1: Provider found (returning user)
                CMD->>UserRepo: findById(oauth.user_id)
                UserRepo->>DB: SELECT users
                DB-->>UserRepo: User
                CMD->>OAuthRepo: save(updated tokens)
                OAuthRepo->>DB: UPDATE user_oauth_providers
                CMD->>CMD: determineRedirectPath(user)
                alt system_role is superadmin/system_admin
                    CMD-->>S: { user, isNewUser: false, redirectTo: '/admin' }
                else current_organization_id exists
                    CMD-->>S: { user, isNewUser: false, redirectTo: '/tasks' }
                else no organization context
                    CMD-->>S: { user, isNewUser: false, redirectTo: '/organizations' }
                end

            else Step 2: existing account by email
                CMD->>UserRepo: findByEmail(email)
                UserRepo->>DB: SELECT users WHERE email = ?
                DB-->>UserRepo: User or null
                UserRepo-->>CMD: User or null

                alt Step 2: Email found (link provider)
                    CMD->>OAuthRepo: create(user_id, provider, provider_id, tokens)
                    OAuthRepo->>DB: INSERT user_oauth_providers
                    CMD->>UserRepo: save(auth_method if changed)
                    UserRepo->>DB: UPDATE users
                    CMD->>CMD: determineRedirectPath(user)
                    alt system_role is superadmin/system_admin
                        CMD-->>S: { user, isNewUser: false, redirectTo: '/admin' }
                    else current_organization_id exists
                        CMD-->>S: { user, isNewUser: false, redirectTo: '/tasks' }
                    else no organization context
                        CMD-->>S: { user, isNewUser: false, redirectTo: '/organizations' }
                    end

                else Step 3: New user (first-time sign-up)
                    Note over CMD, DB: DB Transaction
                    CMD->>UserRepo: create active registered_user
                    UserRepo->>DB: INSERT users
                    DB-->>UserRepo: User created
                    CMD->>OAuthRepo: create OAuth provider record
                    OAuthRepo->>DB: INSERT user_oauth_providers
                    CMD-->>S: { user, isNewUser: true, redirectTo: '/organizations' }
                end
            end

            S->>S: auth.use('web').login(user)<br/>→ Create server session (cookie)
            S-->>B: 302 Redirect
            B-->>U: Show admin, tasks, or organizations surface
        end
    end

    Note over U, DB: Logout is session invalidation only

    U->>B: Click "Logout"
    B->>S: POST /logout
    S->>S: auth.use('web').logout()
    S->>S: session forget + shared-data cleanup
    S->>S: emit user:logout
    S-->>B: Redirect /login + flash message
    B-->>U: Show login page
