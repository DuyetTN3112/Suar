%% seq_02_task_crud.mmd
%% Scope: Task CRUD operations (Create, Update, Status Change, Assign, Delete)
%% Backend refs:
%%   - POST /tasks → CreateTaskController → CreateTaskCommand
%%   - PUT /tasks/:id → EditTaskController → UpdateTaskCommand
%%   - PUT /tasks/:id/status → UpdateTaskStatusController → UpdateTaskStatusCommand
%%   - DELETE /tasks/:id → DeleteTaskController → DeleteTaskCommand
%%   - AssignTaskCommand (called from UpdateTaskCommand, no dedicated route)
%%   - ⚠️ No dedicated visibility change or assign route
%%   - ⚠️ Transmit transport=null (no WebSocket delivery)

sequenceDiagram
    autonumber
    actor U as User
    participant B as Browser (Svelte)
    participant C as Controller
    participant Cmd as Command
    participant Entity as Domain Entity
    participant Repo as Repository
    participant DB as PostgreSQL
    participant Evt as Event Bus

    Note over U, Evt: === CREATE TASK ===
    Note over C: CreateTaskController

    U->>B: Fill task creation form
    B->>C: POST /tasks
    C->>C: Validate (createTaskValidator)
    C->>Cmd: CreateTaskCommand.execute(dto)
    Note over Cmd: App Mapper: Request DTO → Domain params
    Cmd->>Cmd: canCreateTask rule
    (checks org role + project role)

    alt Unauthorized
        Cmd-->>C: ForbiddenException
        C-->>B: 403 Forbidden
    else Authorized
        Cmd->>Entity: Task.create(project_id, title,<br/>status='todo', task_visibility='internal', ...)
        Note over Entity: Domain validation
        Cmd->>Repo: save(taskEntity)
        Note over Repo: Infra Mapper: Domain Entity → ORM Model
        Repo->>DB: INSERT INTO tasks
        (project_id, title, status='todo',
        task_visibility='internal', ...)
        DB-->>Repo: Task created
        Repo-->>Cmd: Persisted Task entity
        Note over Cmd: ⚠️ NO task_version on create
        Note over Cmd: Version only on UpdateTaskCommand
        Cmd->>Evt: emit('task:created', task)
        Note over Cmd: App Mapper: Domain Entity → Response DTO
        Cmd-->>C: Task object
        C-->>B: Redirect to task detail
    end

    Note over U, Evt: === UPDATE TASK ===
    Note over C: EditTaskController

    U->>B: Edit task fields
    B->>C: PUT /tasks/:id
    C->>Cmd: UpdateTaskCommand.execute(dto)
    Note over Cmd: App Mapper: Request DTO → Domain params
    Cmd->>Cmd: canUpdateTask rule
    Cmd->>Repo: findById(taskId, lock=true)
    Repo->>DB: SELECT task (with lock)
    DB-->>Repo: Result
    Note over Repo: Infra Mapper: ORM Model → Domain Entity
    Repo-->>Cmd: Task entity
    Cmd->>Entity: task.update(changes)
    Cmd->>Cmd: dto.getChangesForAudit(oldValues)
    Cmd->>Repo: save(taskEntity)
    Note over Repo: Infra Mapper: Domain Entity → ORM Model
    Repo->>DB: UPDATE tasks SET ... WHERE id = ?
    DB-->>Repo: Updated
    Cmd->>Repo: saveVersion(taskVersionEntity)
    Repo->>DB: INSERT INTO task_versions
    (snapshot of changed fields)
    Cmd->>Evt: emit('task:updated', { task, changes })
    Cmd-->>C: Updated task
    C-->>B: Redirect back

    Note over U, Evt: === CHANGE STATUS ===
    Note over C: UpdateTaskStatusController

    U->>B: Change task status
    B->>C: PUT /tasks/:id/status
    C->>Cmd: UpdateTaskStatusCommand.execute(dto)
    Cmd->>Repo: findById(taskId)
    Repo->>DB: SELECT task
    DB-->>Repo: Result
    Repo-->>Cmd: Task entity
    Cmd->>Entity: task.validateTransition(current, target)

    alt Invalid transition
        Entity-->>Cmd: ValidationException
        Cmd-->>C: ValidationException
        C-->>B: 422 Invalid transition
    else todo → in_progress
        Cmd->>Entity: Check assigned_to ≠ null
        alt No assignee
            Cmd-->>C: Error: requires assignee
        else Has assignee
            Cmd->>Entity: task.changeStatus('in_progress')
            Cmd->>Repo: save(taskEntity)
            Repo->>DB: UPDATE tasks SET status = 'in_progress'
            Cmd->>Evt: emit('task:status:changed')
        end
    else Other valid transition
        Cmd->>Entity: task.changeStatus(newStatus)
        Cmd->>Repo: save(taskEntity)
        Repo->>DB: UPDATE tasks SET status = ?
        Cmd->>Evt: emit('task:status:changed',
        { taskId, oldStatus, newStatus })
    end

    Note over Evt: When newStatus = 'done':
    Note over Evt: → auto-complete assignments
    Note over Evt: → auto-create ReviewSessions

    Note over U, Evt: === ASSIGN TASK ===
    Note over C: (via UpdateTaskCommand)

    U->>B: Set assigned_to on task
    B->>C: PUT /tasks/:id
    (body includes assigned_to)
    C->>Cmd: UpdateTaskCommand → AssignTaskCommand
    Cmd->>Repo: findById(taskId)
    Repo->>DB: SELECT task
    DB-->>Repo: Result
    Repo-->>Cmd: Task entity
    Cmd->>Entity: task.assignTo(userId)
    Note over Entity: ⚠️ Status stays UNCHANGED
    Note over Entity: Assignment does NOT create
    Note over Entity: task_assignments row
    Cmd->>Repo: save(taskEntity)
    Repo->>DB: UPDATE tasks SET assigned_to = ?
    Cmd->>Evt: emit('task:assigned', { task, assignee })
    Cmd-->>C: OK
    C-->>B: Updated

    Note over U, Evt: === DELETE TASK ===
    Note over C: DeleteTaskController

    U->>B: Click delete task
    B->>C: DELETE /tasks/:id
    C->>Cmd: DeleteTaskCommand.execute(dto)
    Cmd->>Cmd: canDeleteTask rule
    (checks org/system role, NO status check)
    Cmd->>Repo: findById(taskId)
    Repo->>DB: SELECT task
    DB-->>Repo: Result
    Repo-->>Cmd: Task entity
    Cmd->>Entity: task.softDelete()
    Cmd->>Repo: save(taskEntity)
    Repo->>DB: UPDATE tasks SET deleted_at = NOW()
    Cmd->>Evt: emit('task:deleted', taskId)
    Cmd-->>C: OK
    C-->>B: Redirect to task list

