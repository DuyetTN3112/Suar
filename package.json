{
  "name": "kidmanager-cms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node --max-old-space-size=4096 bin/server.js",
    "build": "USE_SVELTE=true node ace build --ignore-ts-errors",
    "dev": "USE_SVELTE=true node --max-old-space-size=4096 ace serve --hmr",
    "dev:svelte": "USE_SVELTE=true node --max-old-space-size=4096 ace serve --hmr",
    "dev:react": "USE_SVELTE=false node --max-old-space-size=4096 ace serve --hmr",
    "build:svelte": "USE_SVELTE=true node ace build --ignore-ts-errors",
    "build:react": "USE_SVELTE=false node ace build --ignore-ts-errors",
    "dev:with-typecheck": "concurrently \"npm run typecheck:watch\" \"npm run dev\"",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "svelte-check": "svelte-check --tsconfig ./inertia/tsconfig.json",
    "test": "node --loader ts-node-maintained/esm bin/test.ts",
    "test:watch": "node --loader ts-node-maintained/esm bin/test.ts --watch",
    "debug": "node vite-debug.js",
    "lint": "eslint .",
    "lint:backend": "eslint ./app ./start ./config ./server.ts",
    "lint:frontend": "eslint ./inertia",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "docker:install": "npm install --no-package-lock --omit=optional && node ./scripts/install-native-modules.js"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#actions/*": "./app/actions/*.js",
    "#constants/*": "./app/constants/*.js",
    "#constants": "./app/constants/index.js",
    "#libs/*": "./app/libs/*.js",
    "#libs": "./app/libs/index.js",
    "#utils/*": "./app/utils/*.js",
    "#helpers/*": "./app/helpers/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/eslint-config": "^2.1.2",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^1.4.1",
    "@japa/assert": "^4.2.0",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@japa/spec-reporter": "^1.3.3",
    "@swc/core": "^1.15.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/feather-icons": "^4.29.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.9",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-formatter-visualstudio": "^9.0.1",
    "eslint-plugin-svelte": "^3.14.0",
    "hot-hook": "^0.4.0",
    "lightningcss": "^1.30.2",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.0",
    "svelte-check": "^4.3.6",
    "svelte-eslint-parser": "^1.4.1",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "ts-node-maintained": "^10.9.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@adonisjs/ally": "^5.1.1",
    "@adonisjs/auth": "^9.5.1",
    "@adonisjs/core": "^6.19.3",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/drive": "^3.4.1",
    "@adonisjs/i18n": "^2.2.3",
    "@adonisjs/inertia": "^3.1.1",
    "@adonisjs/limiter": "^2.4.0",
    "@adonisjs/lock": "^1.1.1",
    "@adonisjs/lucid": "^21.8.2",
    "@adonisjs/redis": "^9.2.0",
    "@adonisjs/session": "^7.7.1",
    "@adonisjs/shield": "^8.2.0",
    "@adonisjs/static": "^1.1.1",
    "@adonisjs/transmit": "^2.0.2",
    "@adonisjs/vite": "^4.0.0",
    "@aws-sdk/client-ses": "^3.971.0",
    "@google-cloud/local-auth": "^3.0.1",
    "@inertiajs/svelte": "^2.3.13",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@vinejs/vine": "^4.2.0",
    "bits-ui": "1.0.0-next.98",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "edge.js": "^6.4.0",
    "feather-icons": "^4.29.2",
    "firebase": "^12.8.0",
    "formsnap": "^2.0.1",
    "googleapis": "^170.1.0",
    "input-otp": "^1.4.2",
    "lucide-svelte": "^0.563.0",
    "luxon": "^3.7.2",
    "mode-watcher": "^1.1.0",
    "mysql2": "^3.16.2",
    "reflect-metadata": "^0.2.2",
    "svelte": "^5.49.1",
    "svelte-sonner": "^1.0.7",
    "sveltekit-superforms": "^2.29.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "youch": "^3.3.4",
    "youch-terminal": "^2.2.3",
    "zod": "^4.3.5"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts",
      "./app/actions/**/*.ts",
      "./app/validators/**/*.ts",
      "./app/services/**/*.ts",
      "./app/models/**/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
