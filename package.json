{
  "name": "kidmanager-cms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node --max-old-space-size=4096 bin/server.js",
    "build": "node ace build --ignore-ts-errors",
    "dev": "node --max-old-space-size=4096 ace serve --hmr",
    "dev:with-typecheck": "concurrently \"npm run typecheck:watch\" \"npm run dev\"",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "svelte-check": "svelte-check --tsconfig ./inertia/tsconfig.json",
    "test": "node --import=@poppinss/ts-exec bin/test.ts",
    "test:unit": "node --import=@poppinss/ts-exec bin/test.ts --files='tests/unit/**/*.spec.ts'",
    "test:match": "node --import=@poppinss/ts-exec bin/test.ts --files='tests/match/**/*.spec.ts'",
    "test:integration": "node --import=@poppinss/ts-exec bin/test.ts --files='tests/integration/**/*.spec.ts'",
    "test:watch": "node --import=@poppinss/ts-exec bin/test.ts --watch",
    "debug": "node vite-debug.js",
    "lint": "eslint .",
    "lint:backend": "eslint ./app ./start ./config ./server.ts",
    "lint:frontend": "eslint ./inertia",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "docker:install": "npm install --no-package-lock --omit=optional && node ./scripts/install-native-modules.js",
    "prepare": "husky"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#actions/*": "./app/actions/*.js",
    "#constants/*": "./app/constants/*.js",
    "#constants": "./app/constants/index.js",
    "#libs/*": "./app/libs/*.js",
    "#libs": "./app/libs/index.js",
    "#utils/*": "./app/utils/*.js",
    "#helpers/*": "./app/helpers/*.js",
    "#types/*": "./app/types/*.js",
    "#repositories/*": "./app/repositories/*.js",
    "#repositories": "./app/repositories/index.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#tests/*": "./tests/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/http-server": "^8.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@japa/spec-reporter": "^1.3.3",
    "@poppinss/ts-exec": "^1.4.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/feather-icons": "^4.29.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.5",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "eslint-formatter-visualstudio": "^9.0.1",
    "eslint-plugin-svelte": "^3.15.0",
    "hot-hook": "^1.0.0",
    "husky": "^9.1.7",
    "lightningcss": "^1.31.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "svelte-check": "^4.4.4",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@adonisjs/ally": "^6.0.0",
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/drive": "^4.0.0",
    "@adonisjs/i18n": "^3.0.0",
    "@adonisjs/inertia": "^4.1.0",
    "@adonisjs/limiter": "^3.0.0",
    "@adonisjs/lock": "^2.1.0",
    "@adonisjs/lucid": "^22.1.0",
    "@adonisjs/redis": "^10.0.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.0",
    "@adonisjs/transmit": "^3.0.1",
    "@adonisjs/vite": "^5.1.0",
    "@aws-sdk/client-ses": "^3.1003.0",
    "@google-cloud/local-auth": "^3.0.1",
    "@inertiajs/svelte": "^2.3.17",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@vinejs/vine": "^4.3.0",
    "axios": "^1.13.6",
    "bits-ui": "2.16.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "edge.js": "^6.5.0",
    "feather-icons": "^4.29.2",
    "firebase": "^12.10.0",
    "formsnap": "^2.0.1",
    "googleapis": "^171.4.0",
    "lucide-svelte": "^0.577.0",
    "luxon": "^3.7.2",
    "mode-watcher": "^1.1.0",
    "mongoose": "^9.2.4",
    "mysql2": "^3.19.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "svelte": "^5.53.7",
    "svelte-sonner": "^1.0.8",
    "sveltekit-superforms": "^2.30.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "youch": "^4.1.0",
    "youch-terminal": "^2.2.3",
    "zod": "^4.3.6"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts",
      "./app/actions/**/*.ts",
      "./app/validators/**/*.ts",
      "./app/services/**/*.ts",
      "./app/models/**/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
