{
  "name": "kidmanager-cms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node --max-old-space-size=4096 bin/server.js",
    "build": "node ace build",
    "build:ignore-ts-errors": "node ace build --ignore-ts-errors",
    "dev": "node --max-old-space-size=4096 ace serve --hmr",
    "dev:with-typecheck": "concurrently \"npm run typecheck:watch\" \"npm run dev\"",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "svelte-check": "svelte-check --tsconfig ./inertia/tsconfig.json",
    "check:svelte": "svelte-check --tsconfig ./inertia/tsconfig.json",
    "check:svelte:watch": "svelte-check --tsconfig ./inertia/tsconfig.json --watch",
    "check:svelte:strict": "svelte-check --tsconfig ./inertia/tsconfig.json --fail-on-warnings",
    "check:arch:frontend": "bash ./scripts/check_frontend_architecture.sh",
    "check:arch:backend:side-effects": "node ./scripts/check_backend_side_effect_boundary.mjs",
    "check:hotspot:ownership": "bash ./scripts/check_hotspot_ownership.sh",
    "check:deps:axios": "bash ./scripts/check_axios_version.sh",
    "generate:page-slice": "bash ./scripts/generate_page_slice.sh",
    "test": "npm run test:unit && npm run test:match",
    "test:all": "node --import=@poppinss/ts-exec bin/test.ts",
    "db:test:migrate": "sh scripts/db_test_migrate.sh",
    "test:integration:safe": "sh scripts/test_integration_safe.sh",
    "test:all:safe": "npm run test:unit && npm run test:match && npm run test:integration:safe",
    "test:full-confidence": "npm run test:all:safe",
    "test:unit": "node --import=@poppinss/ts-exec bin/test.ts unit",
    "test:match": "node --import=@poppinss/ts-exec bin/test.ts match",
    "test:integration": "node --import=@poppinss/ts-exec bin/test.ts integration",
    "test:watch": "node --import=@poppinss/ts-exec bin/test.ts --watch",
    "debug": "node vite-debug.js",
    "lint": "concurrently --group --timings \"npm run lint:backend:app\" \"npm run lint:backend:rest\" \"npm run lint:frontend\"",
    "lint:backend": "concurrently --group \"npm run lint:backend:app\" \"npm run lint:backend:rest\"",
    "lint:backend:app": "eslint ./app --cache --cache-location .cache/eslint/app",
    "lint:backend:rest": "eslint ./bin ./start ./config ./types ./tests ./server.ts --cache --cache-location .cache/eslint/rest",
    "lint:frontend": "concurrently --group \"npm run lint:frontend:svelte\" \"npm run lint:frontend:ts\"",
    "lint:frontend:svelte": "eslint \"inertia/**/*.svelte\" --cache --cache-location .cache/eslint/frontend-svelte",
    "lint:frontend:ts": "eslint \"inertia/**/*.ts\" --cache --cache-location .cache/eslint/frontend-ts",
    "lint:fix": "concurrently --group \"npm run lint:backend:app -- --fix\" \"npm run lint:backend:rest -- --fix\" \"npm run lint:frontend:svelte -- --fix\" \"npm run lint:frontend:ts -- --fix\"",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "docker:install": "npm install --no-package-lock --omit=optional && node ./scripts/install-native-modules.js",
    "prepare": "husky"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#domain/*": "./app/domain/*.js",
    "#actions/*": "./app/actions/*.js",
    "#constants/*": "./app/constants/*.js",
    "#constants": "./app/constants/index.js",
    "#libs/*": "./app/libs/*.js",
    "#libs": "./app/libs/index.js",
    "#utils/*": "./app/utils/*.js",
    "#helpers/*": "./app/helpers/*.js",
    "#types/*": "./app/types/*.js",
    "#infra/*": "./app/infra/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#tests/*": "./tests/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/http-server": "^8.2.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@adonisjs/vite": "^5.1.1",
    "@japa/assert": "^4.2.0",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@japa/spec-reporter": "^1.3.3",
    "@poppinss/ts-exec": "^1.4.4",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/feather-icons": "^4.29.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-formatter-visualstudio": "^9.0.1",
    "eslint-parallel": "^1.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-svelte": "^3.17.1",
    "hot-hook": "^1.0.0",
    "husky": "^9.1.7",
    "lightningcss": "^1.32.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11"
  },
  "dependencies": {
    "@adonisjs/ally": "^6.3.0",
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/core": "^7.3.2",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/drive": "^4.0.0",
    "@adonisjs/i18n": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/limiter": "^3.0.1",
    "@adonisjs/lock": "^2.1.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/redis": "^10.0.0",
    "@adonisjs/session": "^8.1.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/transmit": "^3.0.1",
    "@aws-sdk/client-ses": "^3.1045.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@google-cloud/local-auth": "^3.0.1",
    "@inertiajs/svelte": "^3.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vinejs/vine": "^4.4.0",
    "axios": "1.16.0",
    "bits-ui": "2.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "edge.js": "^6.5.0",
    "feather-icons": "^4.29.2",
    "formsnap": "^2.0.1",
    "googleapis": "^171.4.0",
    "lucide-svelte": "^1.0.1",
    "luxon": "^3.7.2",
    "mode-watcher": "^1.1.0",
    "mongoose": "^9.6.2",
    "mysql2": "^3.22.3",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "svelte": "^5.55.5",
    "svelte-sonner": "^1.1.1",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "youch": "^4.1.1",
    "youch-terminal": "^2.2.3",
    "zod": "^4.4.3"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts",
      "./app/actions/**/*.ts",
      "./app/validators/**/*.ts",
      "./app/infra/**/*.ts",
      "./app/libs/**/*.ts",
      "./app/services/**/*.ts",
      "./app/models/**/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "core-js",
      "esbuild",
      "protobufjs"
    ]
  }
}
